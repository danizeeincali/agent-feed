{
  "workflow_id": "white_screen_systematic_debugging",
  "version": "1.0",
  "created_by": "nld-agent",
  "workflow_steps": [
    {
      "step": 1,
      "name": "initial_assessment",
      "description": "Gather symptoms and context",
      "actions": [
        "Document user-reported symptoms exactly",
        "Check if server is running (curl localhost:port)",
        "Verify HTML is being served",
        "Note any visible error messages"
      ],
      "success_criteria": "Clear understanding of failure scope",
      "neural_confidence": 0.98
    },
    {
      "step": 2, 
      "name": "build_verification",
      "description": "Check build process integrity",
      "actions": [
        "Run npm run build",
        "Identify any build errors",
        "Note specific error messages and file locations",
        "Check for missing dependencies"
      ],
      "success_criteria": "Build completes without errors OR errors identified",
      "neural_confidence": 0.92
    },
    {
      "step": 3,
      "name": "import_export_analysis", 
      "description": "Validate module resolution",
      "actions": [
        "Trace import statements in failing files",
        "Verify exports exist in target modules",
        "Check barrel export files (index.ts)",
        "Validate import paths are correct"
      ],
      "success_criteria": "All imports resolve to valid exports",
      "neural_confidence": 0.89
    },
    {
      "step": 4,
      "name": "resolution_application",
      "description": "Apply targeted fixes",
      "actions": [
        "Fix missing exports in barrel files",
        "Update incorrect import paths", 
        "Add missing dependencies if needed",
        "Re-run build to verify fixes"
      ],
      "success_criteria": "Build succeeds and UI loads",
      "neural_confidence": 0.95
    },
    {
      "step": 5,
      "name": "validation_testing",
      "description": "Confirm resolution completeness",
      "actions": [
        "Test app loads in browser",
        "Check for console errors",
        "Verify all major UI components render",
        "Perform basic functionality test"
      ],
      "success_criteria": "Application functions as expected",
      "neural_confidence": 0.97
    }
  ],
  "fallback_strategies": [
    {
      "if": "build_errors_persist",
      "then": "clear_node_modules_and_reinstall"
    },
    {
      "if": "import_resolution_complex",
      "then": "create_explicit_import_paths"
    },
    {
      "if": "multiple_missing_exports", 
      "then": "audit_entire_api_structure"
    }
  ],
  "prevention_integration": {
    "recommended_tests": [
      "pre-commit build validation",
      "import contract testing",
      "smoke test CI/CD integration"
    ],
    "monitoring": [
      "build success rate tracking",
      "import error alerting",
      "user experience monitoring"
    ]
  }
}