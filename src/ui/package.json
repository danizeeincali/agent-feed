{
  "name": "@agent-feed/ui-modernization",
  "version": "1.0.0",
  "description": "Professional UI Components with Claudable styling patterns - Generated by Swarm Coordination System",
  "keywords": [
    "react",
    "ui-components", 
    "claude-interface",
    "chat-ui",
    "professional-styling",
    "accessibility",
    "performance-optimized"
  ],
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./components": "./components/index.ts",
    "./utils": "./utils/index.ts",
    "./testing": "./testing/index.ts",
    "./performance": "./performance/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "jest",
    "test:regression": "jest --config jest.regression.config.js",
    "test:performance": "jest --config jest.performance.config.js",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "validate-swarm": "node scripts/validate-swarm-coordination.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "framer-motion": "^10.16.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.4.0",
    "typescript": "^5.0.0",
    "eslint": "^8.45.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "files": [
    "components/",
    "utils/",
    "testing/",
    "performance/",
    "swarm-coordination.ts",
    "index.ts",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-feed/ui-modernization"
  },
  "author": "Agent Feed UI Modernization Swarm",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "swarm": {
    "topology": "adaptive",
    "agents": {
      "ui-component-specialist": 4,
      "styling-integration-specialist": 3,
      "chat-interface-specialist": 3,
      "testing-validation-specialist": 3,
      "performance-optimization-specialist": 2
    },
    "coordination": {
      "conflictResolution": "intelligent-merge",
      "dependencyManagement": "real-time",
      "qualityAssurance": "continuous",
      "regressionTesting": "automated"
    },
    "performance": {
      "renderTimeThreshold": "16ms",
      "memoryThreshold": "50MB",
      "bundleSizeThreshold": "1MB",
      "accessibilityScore": "95+",
      "testCoverage": "90+"
    }
  },
  "claudable": {
    "patterns": {
      "colors": ["blue-500", "gray-100", "gray-900"],
      "animations": ["smooth-transitions", "micro-interactions"],
      "accessibility": ["keyboard-navigation", "aria-compliance"],
      "responsive": ["mobile-first", "desktop-optimized"]
    },
    "compatibility": {
      "darkMode": true,
      "rightToLeft": false,
      "touchOptimized": true,
      "keyboardNavigation": true
    }
  }
}