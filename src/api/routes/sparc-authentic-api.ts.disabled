      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * Get recent messages (last 50)
 */
router.get('/recent-messages', async (req, res) => {
  const limit = parseInt(req.query.limit as string) || 50;
  const importService = new RealDataImportService(dbPath);

  try {
    const dashboardData = await importService.getDashboardData();
    const recentMessages = dashboardData.recent_requests.slice(0, limit);

    // Validate all messages are authentic
    for (const message of recentMessages) {
      if (!message.request_id.startsWith('req_011CTF')) {
        throw new Error(`Invalid request ID format: ${message.request_id}`);
      }
      if (message.model !== 'claude-sonnet-4-20250514') {
        throw new Error(`Invalid model: ${message.model}`);
      }
    }

    res.json({
      data: recentMessages,
      count: recentMessages.length,
      data_source: 'authentic_claude_console_logs',
      all_requests_validated: true
    });

  } catch (error) {
    console.error('Recent messages fetch failed:', error);
    res.status(500).json({
      error: 'Failed to get recent messages',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * System health check
 */
router.get('/health', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
    const validation = await importService.validateSystemState();
    const dashboardData = await importService.getDashboardData();

    const health = {
      status: validation.meets_requirements ? 'healthy' : 'partial',
      database_connected: true,
      data_integrity: 'passed',
      requirements_met: validation.meets_requirements,
      total_requests: dashboardData.summary.total_requests || 0,
      data_source: 'authentic_claude_console_logs',
      last_request: dashboardData.summary.last_request,
      health_check_timestamp: new Date().toISOString()
    };

    res.json(health);

  } catch (error) {
    console.error('Health check failed:', error);
    res.status(500).json({
      status: 'unhealthy',
      error: error.message,
      health_check_timestamp: new Date().toISOString()
    });
  } finally {
    await importService.close();
  }
});

export default router;