/**
 * SPARC Phase 5 - COMPLETION: Authentic Data API Routes
 * API endpoints serving 100% real Claude Console data
 */

import express from 'express';
import { RealDataImportService } from '../../sparc/real-data-import/data-import-service.js';
import { detector } from '../../middleware/fake-data-detector.js';
import path from 'path';

const router = express.Router();

// Apply fake data detection middleware to all routes
router.use(detector.middleware({
  blockOnError: true,
  logWarnings: true,
  includeResponse: true
}));

// Database path for authentic data
const dbPath = path.join(process.cwd(), 'data', 'authentic-token-analytics.db');

/**
 * Get authentic dashboard data
 */
router.get('/authentic-dashboard', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
    const dashboardData = await importService.getDashboardData();

    // Validate data authenticity before responding
    const validation = detector.validateTokenAnalytics({
      cost: dashboardData.summary.total_cost,
      tokens: dashboardData.summary.total_input_tokens + dashboardData.summary.total_output_tokens,
      messages: dashboardData.recent_requests
    });

    if (!validation.valid) {
      await importService.close();
      return res.status(400).json({
        error: 'Data failed authenticity validation',
        validation_errors: validation.errors,
        validation_warnings: validation.warnings
      });
    }

    res.json({
      ...dashboardData,
      data_source: 'authentic_claude_console_logs',
      validation_status: 'passed',
      generated_at: new Date().toISOString()
    });

  } catch (error) {
    console.error('Dashboard data fetch failed:', error);
    res.status(500).json({
      error: 'Failed to fetch authentic dashboard data',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * Get validation status against requirements
 */
router.get('/validation-status', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
    const validation = await importService.validateSystemState();

    res.json({
      ...validation,
      requirements: {
        target_cost: 8.43,
        target_input_tokens: 5784733,
        target_output_tokens: 30696,
        target_model: 'claude-sonnet-4-20250514'
      },
      checked_at: new Date().toISOString()
    });

  } catch (error) {
    console.error('Validation status fetch failed:', error);
    res.status(500).json({
      error: 'Failed to get validation status',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * Import console log file
 */
router.post('/import-console-log', async (req, res) => {
  const { file_path, batch_id } = req.body;

  if (!file_path) {
    return res.status(400).json({
      error: 'Missing required parameter: file_path'
    });
  }

  const importService = new RealDataImportService(dbPath);

  try {
    const result = await importService.importConsoleLogFile(file_path);

    if (!result.success) {
      return res.status(400).json({
        error: 'Import failed',
        import_result: result
      });
    }

    res.json({
      message: 'Console log imported successfully',
      import_result: result,
      next_steps: result.validation.meets_requirements
        ? 'All requirements met - dashboard ready'
        : 'Import more data to meet requirements'
    });

  } catch (error) {
    console.error('Console log import failed:', error);
    res.status(500).json({
      error: 'Failed to import console log',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * Import authentic sample data (for testing/demo)
 */
router.post('/import-sample-data', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
