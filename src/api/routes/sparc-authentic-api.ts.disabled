/**
 * Purge any fake data (emergency cleanup)
 */
router.post('/purge-fake-data', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
    const purgeResult = await importService.purgeFakeData();
    const validation = await importService.validateSystemState();

    res.json({
      message: 'Fake data purge completed',
      purge_result: purgeResult,
      current_status: validation,
      note: 'System now contains only authentic data'
    });

  } catch (error) {
    console.error('Fake data purge failed:', error);
    res.status(500).json({
      error: 'Failed to purge fake data',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

/**
 * Get hourly usage trends (Chart.js format)
 */
router.get('/hourly-trends', async (req, res) => {
  const importService = new RealDataImportService(dbPath);

  try {
    const dashboardData = await importService.getDashboardData();
    const hourlyData = dashboardData.hourly_trends;

    // Format for Chart.js
    const chartData = {
      labels: hourlyData.map(h => new Date(h.hour).toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'})),
      datasets: [
        {
          label: 'Tokens Used',
          data: hourlyData.map(h => h.total_input + h.total_output),
          backgroundColor: 'rgba(59, 130, 246, 0.5)',
          borderColor: 'rgb(59, 130, 246)',
          yAxisID: 'y'
        },
        {
          label: 'Cost (cents)',
          data: hourlyData.map(h => h.hourly_cost * 100),
          backgroundColor: 'rgba(16, 185, 129, 0.5)',
          borderColor: 'rgb(16, 185, 129)',
          yAxisID: 'y1'
        }
      ]
    };

    res.json({
      data: chartData,
      raw: hourlyData,
      data_source: 'authentic_claude_console_logs'
    });

  } catch (error) {
    console.error('Hourly trends fetch failed:', error);
    res.status(500).json({
      error: 'Failed to get hourly trends',
      details: error.message
    });
  } finally {
    await importService.close();
  }
});

