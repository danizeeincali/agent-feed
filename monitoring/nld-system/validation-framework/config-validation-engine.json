  "validation_rules_engine": {
    "claude_code_specific_rules": [
      {
        "rule_id": "CLAUDE-CONFIG-001",
        "rule_name": "workspace_boundary_enforcement",
        "description": "All file operations must stay within workspace boundary",
        "validation_logic": {
          "check": "all paths in allowed_directories are within workspace",
          "constraint": "no path contains '../' or resolves outside workspace",
          "severity": "critical",
          "auto_fix": false
        }
      },
      
      {
        "rule_id": "CLAUDE-CONFIG-002", 
        "rule_name": "environment_isolation_integrity",
        "description": "Environment-specific configs must not leak between environments",
        "validation_logic": {
          "check": "dev configs contain no production URLs or credentials",
          "constraint": "prod configs accessible only in production environment", 
          "severity": "high",
          "auto_fix": true
        }
      },
      
      {
        "rule_id": "CLAUDE-CONFIG-003",
        "rule_name": "forbidden_operations_enforcement",
        "description": "All operations in forbidden list must be blocked",
        "validation_logic": {
          "check": "forbidden_operations list is complete and enforced",
          "constraint": "no agent can execute forbidden operations",
          "severity": "critical",
          "auto_fix": false
        }
      },
      
      {
        "rule_id": "CLAUDE-CONFIG-004",
        "rule_name": "configuration_hierarchy_consistency",
        "description": "Config hierarchy must resolve consistently",
        "validation_logic": {
          "check": "global -> feature -> environment -> instance hierarchy works",
          "constraint": "no circular dependencies or conflicting overrides",
          "severity": "medium",
          "auto_fix": true
        }
      }
    ],
    
    "security_focused_rules": [
      {
        "rule_id": "SEC-001",
        "rule_name": "no_hardcoded_secrets",
        "description": "Configuration must not contain hardcoded secrets",
        "validation_logic": {
          "check": "scan for patterns matching secrets (API keys, passwords, tokens)",
          "constraint": "all secrets must use environment variables or secure storage",
          "severity": "critical",
          "auto_fix": false
        }
      },
      
      {
        "rule_id": "SEC-002",
        "rule_name": "minimal_privilege_principle", 
        "description": "Agents must have minimal required privileges",
        "validation_logic": {
          "check": "agent permissions match their required capabilities",
          "constraint": "no overly broad or unnecessary permissions granted",
          "severity": "high",
          "auto_fix": true
        }
      }
    ]
  },
  
