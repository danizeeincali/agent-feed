# ==============================================================================
# Phase 1: Development Environment Configuration
# ==============================================================================
# IMPORTANT: Copy this file to .env.phase1.local and set your actual values
# Never commit .env.phase1.local to version control!
# ==============================================================================

# ==============================================================================
# Directory Structure Configuration
# ==============================================================================
# These paths define the core directory structure for the agent system

# Root workspace directory (usually the project root)
WORKSPACE_ROOT=/workspaces/agent-feed

# Project root directory (same as workspace for single-project setups)
PROJECT_ROOT=/workspaces/agent-feed

# Claude production directory (for production agent data)
CLAUDE_PROD_DIR=/workspaces/agent-feed/.claude

# Claude configuration directory (for agent configs)
CLAUDE_CONFIG_DIR=/workspaces/agent-feed/.claude/config

# Claude memory directory (for agent memory/state)
CLAUDE_MEMORY_DIR=/workspaces/agent-feed/.claude/memory

# Claude logs directory (for agent execution logs)
CLAUDE_LOGS_DIR=/workspaces/agent-feed/.claude/logs

# Agents directory (for agent definitions and templates)
AGENTS_DIR=/workspaces/agent-feed/agents

# Agent workspace directory (for agent runtime workspaces)
AGENT_WORKSPACE_DIR=/workspaces/agent-feed/agents/workspace

# Agent templates directory (for agent templates)
AGENT_TEMPLATES_DIR=/workspaces/agent-feed/config/system/agent-templates

# Database directory (for SQLite databases if not using PostgreSQL)
DATABASE_DIR=/workspaces/agent-feed/data

# Token analytics database path (for token usage tracking)
TOKEN_ANALYTICS_DB_PATH=/workspaces/agent-feed/data/token-analytics.db

# Agents configuration file path (for agent system configuration)
AGENTS_CONFIG_PATH=/workspaces/agent-feed/config/agents.json

# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================

# Database connection
POSTGRES_DB=avidm_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password_change_in_production

# Database host and port
DB_HOST=localhost
DB_PORT=5432

# Full connection string (used by application)
DATABASE_URL=postgresql://postgres:dev_password_change_in_production@localhost:5432/avidm_dev

# For PgBouncer (uncomment when using connection pooling in production)
# DB_HOST=localhost
# DB_PORT=6432
# DATABASE_URL=postgresql://postgres:dev_password_change_in_production@localhost:6432/avidm_dev

# ==============================================================================
# Claude API Configuration
# ==============================================================================

ANTHROPIC_API_KEY=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

# Claude Model Selection (Phase 1 uses latest models)
AGENT_MODEL=claude-sonnet-4-5-20250929
AVI_MODEL=claude-sonnet-4-5-20250929

# ==============================================================================
# Application Environment
# ==============================================================================

NODE_ENV=development
LOG_LEVEL=info

# ==============================================================================
# Phase 2A: Database Selection (Dual Mode Support)
# ==============================================================================
# Set to 'true' to use PostgreSQL, 'false' to use SQLite
USE_POSTGRES=true

# ==============================================================================
# Connection Pool Settings (Application-Level)
# ==============================================================================

# Pool size formula: CPU cores × 2 (e.g., 4 cores = 8-16 connections)
DB_POOL_MIN=4
DB_POOL_MAX=16
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000
DB_STATEMENT_TIMEOUT_MS=30000

# ==============================================================================
# Health Check Settings
# ==============================================================================

HEALTH_CHECK_INTERVAL=30000
AVI_CONTEXT_LIMIT=50000

# ==============================================================================
# Agent Worker Settings
# ==============================================================================

MAX_AGENT_WORKERS=10
RETRY_MAX_ATTEMPTS=3

# ==============================================================================
# Platform API (placeholder - add your platform credentials)
# ==============================================================================

PLATFORM_API_KEY=your_platform_api_key_here

# ==============================================================================
# Backup Settings
# ==============================================================================

BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# ==============================================================================
# Security (Production Only)
# ==============================================================================
# Use Docker secrets instead of environment variables in production
# DB_PASSWORD_FILE=/run/secrets/db_password
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# ==============================================================================
# Container Names (for scripts)
# ==============================================================================

CONTAINER_NAME=agent-feed-postgres-phase1

# ==============================================================================
# Application User (for non-superuser database access)
# ==============================================================================

APP_USER_PASSWORD=app_password_change_in_production
