# Database Configuration (Docker)
DATABASE_URL=postgresql://agent_user:agent_password@localhost:5432/agent_feed
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent_feed
DB_USER=agent_user
DB_PASSWORD=agent_password
DB_SSL=false

# Redis Configuration  
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Authentication
JWT_SECRET=dev-jwt-secret-change-in-production-3a7b9c2d8e1f4g6h5i9j
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Claude OAuth (placeholder - replace with actual values when available)
CLAUDE_CLIENT_ID=your-claude-client-id
CLAUDE_CLIENT_SECRET=your-claude-client-secret
CLAUDE_REDIRECT_URI=http://localhost:3000/auth/claude/callback

# Claude Flow Configuration
CLAUDE_FLOW_ENABLED=true
CLAUDE_FLOW_MAX_AGENTS=10
CLAUDE_FLOW_DEFAULT_TOPOLOGY=mesh

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WEBSOCKET_ENABLED=true
WEBSOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
