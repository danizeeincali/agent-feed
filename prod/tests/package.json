{
  "name": "agent-feed-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end testing suite for Agent Feed Enhancement System",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:codegen": "playwright codegen",
    "test:report": "playwright show-report",
    "test:workflows": "playwright test workflows/",
    "test:coordination": "playwright test workflows/multi-agent-coordination.spec.js",
    "test:performance": "playwright test --project=performance",
    "test:visual": "playwright test --project=visual-regression",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:api": "playwright test --project=api",
    "test:error-scenarios": "playwright test error-scenarios/",
    "test:parallel": "playwright test --workers=4",
    "test:shard": "playwright test --shard=1/4",
    "test:chrome": "playwright test --project=chromium-desktop",
    "test:firefox": "playwright test --project=firefox-desktop", 
    "test:webkit": "playwright test --project=webkit-desktop",
    "install:browsers": "playwright install",
    "install:deps": "playwright install-deps",
    "setup": "npm run install:browsers && npm run install:deps",
    "setup:ci": "npx playwright install --with-deps",
    "lint": "eslint e2e/ --ext .js",
    "lint:fix": "eslint e2e/ --ext .js --fix",
    "typecheck": "tsc --noEmit",
    "update:screenshots": "playwright test --update-snapshots",
    "clean": "rm -rf test-results/ && rm -rf playwright-report/",
    "clean:screenshots": "rm -rf test-results/screenshots/",
    "coverage:merge": "node scripts/merge-coverage.js",
    "reports:generate": "node scripts/generate-reports.js",
    "reports:consolidate": "node scripts/consolidate-reports.js",
    "reports:publish": "node scripts/publish-reports.js",
    "perf:baseline": "node scripts/update-performance-baseline.js",
    "perf:compare": "node scripts/compare-performance.js",
    "data:seed": "node scripts/seed-test-data.js",
    "data:clean": "node scripts/clean-test-data.js",
    "docker:up": "docker-compose -f docker/test-stack.yml up -d",
    "docker:down": "docker-compose -f docker/test-stack.yml down",
    "ci:install": "npm ci && npm run setup:ci",
    "ci:test": "npm run test -- --reporter=github",
    "ci:coverage": "npm run test -- --reporter=json --output-file=test-results/results.json",
    "dev:watch": "playwright test --watch",
    "dev:server": "node scripts/dev-server.js"
  },
  "dependencies": {
    "@playwright/test": "^1.40.0",
    "@faker-js/faker": "^8.3.1"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "eslint-plugin-playwright": "^0.18.0",
    "typescript": "^5.3.3",
    "allure-playwright": "^2.10.0",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation",
    "agent-feed",
    "qa"
  ],
  "author": "QA Team",
  "license": "MIT"
}