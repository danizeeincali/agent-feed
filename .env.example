# AgentLink + Claude Code VPS Environment Configuration

# === ESSENTIAL CONFIGURATION ===
# Claude API Key (REQUIRED)
CLAUDE_API_KEY=your_claude_api_key_here

# === DATABASE CONFIGURATION ===
POSTGRES_PASSWORD=agentlink_secure_2025
DATABASE_URL=postgresql://agentlink:agentlink_secure_2025@postgres:5432/agentlink

# === REDIS CONFIGURATION ===
REDIS_PASSWORD=agentlink_redis_2025
REDIS_URL=redis://:agentlink_redis_2025@redis:6379

# === APPLICATION SECURITY ===
JWT_SECRET=agentlink_jwt_secret_2025_very_secure

# === MONITORING PASSWORDS ===
GRAFANA_PASSWORD=agentlink_grafana_2025

# === APPLICATION PORTS ===
# Main application port
PORT=3002

# Claude Code Orchestrator port  
ORCHESTRATOR_PORT=8000

# Monitoring ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# === CORS CONFIGURATION ===
CORS_ORIGIN=http://localhost:3002,http://localhost:3000,http://localhost:5000

# === FEATURE FLAGS ===
WEBSOCKET_ENABLED=true
CLAUDE_FLOW_ENABLED=true

# === RATE LIMITING ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# === LOGGING ===
LOG_LEVEL=info
NODE_ENV=production

# === BUILD INFO (Auto-generated) ===
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
VCS_REF=latest