# Agent Feed Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/agent_feed
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agent_feed
DB_USER=username
DB_PASSWORD=password

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_BASE_URL=http://localhost:3001/api/v1
FRONTEND_URL=http://localhost:3000

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001

# WebSocket Hub Configuration (NEW)
WEBSOCKET_HUB_ENABLED=false
WEBSOCKET_HUB_PORT=3001
WEBSOCKET_HUB_MAX_CONNECTIONS=2000
WEBSOCKET_HUB_SECURITY=true
WEBSOCKET_HUB_METRICS=true
WEBSOCKET_HUB_ROUTING_STRATEGY=hybrid

# Neural Learning Development (NLD) System
NLD_ENABLED=true
NLD_NEURAL_TRAINING=true
NLD_PERFORMANCE_MONITORING=true
NLD_TROUBLESHOOTING=true
NLD_ADAPTIVE_RETRY=true

# Claude Flow Integration
CLAUDE_FLOW_ENABLED=true
CLAUDE_FLOW_MCP_SERVER_URL=ws://localhost:3001/mcp
CLAUDE_FLOW_NEURAL_TRAINING=true
CLAUDE_FLOW_MEMORY_NAMESPACE=agent_feed
CLAUDE_FLOW_TASK_ORCHESTRATION=true

# Security Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3004
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3004,http://127.0.0.1:3001

# Webhook Configuration for Protocol Translation
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# Claude Instance Configuration
CLAUDE_PRODUCTION_URL=https://api.anthropic.com
CLAUDE_DEV_URL=http://localhost:8000
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_WEBHOOK_URL=https://your-domain.com/api/v1/claude-webhook

# Monitoring and Metrics
METRICS_ENABLED=true
METRICS_RETENTION_HOURS=24
PERFORMANCE_MONITORING=true
ALERT_WEBHOOK_URL=https://your-monitoring-service.com/alerts

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/combined.log
ERROR_LOG_FILE=logs/error.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14