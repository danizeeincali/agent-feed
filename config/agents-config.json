  "workflows": {
    "sparc_development": {
      "name": "SPARC Development Workflow",
      "description": "Complete SPARC methodology implementation workflow",
      "agents": ["chief-of-staff", "backend", "frontend", "testing", "documentation"],
      "phases": [
        {
          "name": "Specification",
          "agents": ["research", "chief-of-staff"],
          "duration": 30
        },
        {
          "name": "Pseudocode",
          "agents": ["backend", "frontend"],
          "duration": 45
        },
        {
          "name": "Architecture",
          "agents": ["backend", "database", "devops"],
          "duration": 60
        },
        {
          "name": "Refinement",
          "agents": ["testing", "code-review", "security"],
          "duration": 90
        },
        {
          "name": "Completion",
          "agents": ["deployment", "monitoring", "documentation"],
          "duration": 30
        }
      ]
    },
    "code_review_process": {
      "name": "Comprehensive Code Review",
      "description": "Multi-agent code review and quality assurance",
      "agents": ["code-review", "security", "performance", "testing"],
      "parallel": true,
