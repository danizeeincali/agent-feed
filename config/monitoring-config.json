{
  "monitoring": {
    "enabled": true,
    "collectInterval": 10000,
    "maxHistoryPoints": 100,
    "autoStart": true
  },
  "metrics": {
    "system": {
      "enabled": true,
      "includeProcessMetrics": true,
      "includeDiskMetrics": true
    },
    "database": {
      "enabled": true,
      "trackQueryPerformance": true,
      "trackTableCounts": true
    },
    "api": {
      "enabled": true,
      "trackEndpoints": true,
      "trackResponseTimes": true,
      "requestWindow": 60000
    },
    "business": {
      "enabled": true,
      "customMetrics": []
    }
  },
  "alerting": {
    "enabled": true,
    "deduplicationWindow": 300000,
    "maxAlertsPerMinute": 100,
    "maxHistorySize": 100,
    "rules": [
      {
        "id": "high_cpu",
        "name": "High CPU Usage",
        "metric": "system.cpu.usage",
        "condition": "greater_than",
        "threshold": 80,
        "severity": "critical",
        "duration": 60000,
        "description": "CPU usage exceeds 80% for more than 1 minute"
      },
      {
        "id": "high_memory",
        "name": "High Memory Usage",
        "metric": "system.memory.usedPercentage",
        "condition": "greater_than",
        "threshold": 85,
        "severity": "warning",
        "duration": 60000,
        "description": "Memory usage exceeds 85% for more than 1 minute"
      },
      {
        "id": "critical_memory",
        "name": "Critical Memory Usage",
        "metric": "system.memory.usedPercentage",
        "condition": "greater_than",
        "threshold": 95,
        "severity": "critical",
        "duration": 30000,
        "description": "Memory usage exceeds 95% for more than 30 seconds"
      },
      {
        "id": "low_disk_space",
        "name": "Low Disk Space",
        "metric": "system.disk.usedPercentage",
        "condition": "greater_than",
        "threshold": 90,
        "severity": "warning",
        "duration": 300000,
        "description": "Disk usage exceeds 90% for more than 5 minutes"
      },
      {
        "id": "critical_disk_space",
        "name": "Critical Disk Space",
        "metric": "system.disk.usedPercentage",
        "condition": "greater_than",
        "threshold": 95,
        "severity": "critical",
        "duration": 60000,
        "description": "Disk usage exceeds 95% for more than 1 minute"
      },
      {
        "id": "database_disconnected",
        "name": "Database Disconnected",
        "metric": "database.connected",
        "condition": "equals",
        "threshold": false,
        "severity": "critical",
        "duration": 0,
        "description": "Database connection lost"
      },
      {
        "id": "high_api_error_rate",
        "name": "High API Error Rate",
        "metric": "api.errorRate",
        "condition": "greater_than",
        "threshold": 5,
        "severity": "warning",
        "duration": 60000,
        "description": "API error rate exceeds 5% for more than 1 minute"
      },
      {
        "id": "critical_api_error_rate",
        "name": "Critical API Error Rate",
        "metric": "api.errorRate",
        "condition": "greater_than",
        "threshold": 20,
        "severity": "critical",
        "duration": 30000,
        "description": "API error rate exceeds 20% for more than 30 seconds"
      },
      {
        "id": "slow_api_response",
        "name": "Slow API Response Times",
        "metric": "api.responseTimePercentiles.p95",
        "condition": "greater_than",
        "threshold": 1000,
        "severity": "warning",
        "duration": 120000,
        "description": "95th percentile response time exceeds 1000ms for more than 2 minutes"
      },
      {
        "id": "no_active_agents",
        "name": "No Active Agents",
        "metric": "business.activeAgents",
        "condition": "equals",
        "threshold": 0,
        "severity": "warning",
        "duration": 300000,
        "description": "No agents are active for more than 5 minutes"
      }
    ],
    "channels": {
      "console": {
        "enabled": true,
        "severityFilter": ["critical", "warning", "info"]
      },
      "file": {
        "enabled": true,
        "path": "./logs/alerts.log",
        "severityFilter": ["critical", "warning"],
        "maxFileSize": 10485760,
        "rotateFiles": true
      },
      "webhook": {
        "enabled": false,
        "url": "https://hooks.example.com/alerts",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer YOUR_TOKEN_HERE"
        },
        "severityFilter": ["critical"],
        "timeout": 5000,
        "retries": 3
      },
      "email": {
        "enabled": false,
        "smtp": {
          "host": "smtp.example.com",
          "port": 587,
          "secure": false,
          "auth": {
            "user": "alerts@example.com",
            "pass": "YOUR_PASSWORD_HERE"
          }
        },
        "from": "alerts@example.com",
        "to": ["team@example.com"],
        "severityFilter": ["critical"],
        "subject": "[ALERT] {{severity}} - {{name}}"
      },
      "slack": {
        "enabled": false,
        "webhookUrl": "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "channel": "#alerts",
        "username": "Monitoring Bot",
        "severityFilter": ["critical", "warning"],
        "mentionUsers": {
          "critical": ["@oncall", "@team"]
        }
      }
    }
  },
  "retention": {
    "metrics": {
      "inMemory": "1h",
      "onDisk": "30d"
    },
    "alerts": {
      "inMemory": 100,
      "onDisk": "90d"
    }
  },
  "endpoints": {
    "metrics": "/api/monitoring/metrics",
    "health": "/api/monitoring/health",
    "alerts": "/api/monitoring/alerts",
    "stats": "/api/monitoring/stats"
  },
  "security": {
    "enableAuth": false,
    "apiKeys": [],
    "rateLimiting": {
      "enabled": true,
      "maxRequests": 100,
      "windowMs": 60000
    }
  }
}
