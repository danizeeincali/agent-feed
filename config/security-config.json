{
  "rateLimits": {
    "global": {
      "windowMs": 900000,
      "max": 1000,
      "message": "Too many requests from this IP, please try again later.",
      "description": "Global rate limit: 1000 requests per 15 minutes"
    },
    "auth": {
      "windowMs": 900000,
      "max": 5,
      "skipSuccessfulRequests": true,
      "message": "Too many authentication attempts, please try again later.",
      "description": "Authentication rate limit: 5 failed attempts per 15 minutes"
    },
    "api": {
      "windowMs": 60000,
      "max": 100,
      "message": "API rate limit exceeded",
      "description": "API rate limit: 100 requests per minute"
    },
    "user": {
      "windowMs": 60000,
      "max": 100,
      "description": "Per-user rate limit: 100 requests per minute"
    },
    "speedLimiter": {
      "windowMs": 900000,
      "delayAfter": 100,
      "delayMs": 100,
      "maxDelayMs": 5000,
      "description": "Slow down after 100 requests, add 100ms per request, max 5s delay"
    }
  },

  "cors": {
    "whitelist": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5173",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:3001",
      "http://127.0.0.1:5173"
    ],
    "credentials": true,
    "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
    "allowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-API-Key",
      "X-CSRF-Token",
      "X-Session-ID",
      "Cache-Control"
    ],
    "exposedHeaders": [
      "X-RateLimit-Limit",
      "X-RateLimit-Remaining",
      "X-RateLimit-Reset"
    ],
    "maxAge": 86400,
    "description": "CORS configuration for allowed origins and headers"
  },

  "helmet": {
    "hsts": {
      "maxAge": 31536000,
      "includeSubDomains": true,
      "preload": true,
      "description": "HTTP Strict Transport Security - 1 year"
    },
    "contentSecurityPolicy": {
      "directives": {
        "defaultSrc": ["'self'"],
        "scriptSrc": ["'self'", "'unsafe-inline'", "'unsafe-eval'"],
        "styleSrc": ["'self'", "'unsafe-inline'"],
        "imgSrc": ["'self'", "data:", "https:"],
        "connectSrc": ["'self'", "http://localhost:*", "ws://localhost:*"],
        "fontSrc": ["'self'", "data:"],
        "objectSrc": ["'none'"],
        "mediaSrc": ["'self'"],
        "frameSrc": ["'none'"],
        "upgradeInsecureRequests": []
      },
      "description": "Content Security Policy to prevent XSS and other injection attacks"
    },
    "frameguard": {
      "action": "deny",
      "description": "Prevent clickjacking by disabling iframe embedding"
    },
    "noSniff": true,
    "xssFilter": true,
    "referrerPolicy": {
      "policy": "strict-origin-when-cross-origin"
    },
    "hidePoweredBy": true,
    "dnsPrefetchControl": {
      "allow": false
    }
  },

  "inputValidation": {
    "maxRequestSize": "10mb",
    "maxJsonSize": "10mb",
    "maxUrlEncodedSize": "10mb",
    "parameterLimit": 1000,
    "description": "Request size limits to prevent DoS attacks"
  },

  "sanitization": {
    "sqlInjection": {
      "enabled": true,
      "patterns": [
        "(\\s|^)(union|select|insert|update|delete|drop|create|alter|exec|execute|script|javascript|eval)(\\s|$)",
        "(\\s|^)(or|and)(\\s+)(\\d+)(\\s*)=(\\s*)(\\d+)",
        "(;|--|/\\*|\\*/|xp_|sp_)",
        "('|\"|\\`)(.*?)(or|and)(.*?)('|\"|\\`)"
      ],
      "description": "SQL injection prevention patterns"
    },
    "xss": {
      "enabled": true,
      "patterns": [
        "<script\\b[^<]*(?:(?!<\\/script>)<[^<]*)*<\\/script>",
        "javascript:",
        "on\\w+\\s*=",
        "<iframe",
        "<object",
        "<embed",
        "eval\\(",
        "expression\\(",
        "vbscript:",
        "data:text\\/html"
      ],
      "description": "XSS prevention patterns"
    },
    "noSqlInjection": {
      "enabled": true,
      "replaceWith": "_",
      "description": "NoSQL injection prevention"
    },
    "parameterPollution": {
      "enabled": true,
      "whitelist": ["sort", "filter", "page", "limit", "fields"],
      "description": "HTTP Parameter Pollution prevention"
    }
  },

  "jwt": {
    "accessTokenExpiry": "1h",
    "refreshTokenExpiry": "7d",
    "issuer": "agent-feed-api",
    "audience": "agent-feed-client",
    "algorithm": "HS256",
    "description": "JWT token configuration"
  },

  "session": {
    "timeoutMs": 1800000,
    "cleanupIntervalMs": 300000,
    "description": "Session timeout: 30 minutes, cleanup every 5 minutes"
  },

  "password": {
    "minLength": 8,
    "maxLength": 128,
    "requireUppercase": true,
    "requireLowercase": true,
    "requireNumbers": true,
    "requireSpecialChars": true,
    "saltRounds": 12,
    "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]",
    "description": "Password requirements for strong authentication"
  },

  "suspiciousActivity": {
    "maxViolations": 10,
    "violationWindowMs": 3600000,
    "logRetentionMs": 86400000,
    "description": "Track suspicious activity: max 10 violations per hour, logs retained for 24 hours"
  },

  "apiKeys": {
    "prefix": "ak_",
    "length": 64,
    "description": "API key configuration"
  },

  "roles": {
    "hierarchy": {
      "super_admin": 5,
      "admin": 4,
      "moderator": 3,
      "user": 2,
      "guest": 1
    },
    "permissions": {
      "guest": ["read:public"],
      "user": [
        "read:public",
        "read:private",
        "write:own",
        "delete:own"
      ],
      "moderator": [
        "read:public",
        "read:private",
        "write:own",
        "write:any",
        "delete:own",
        "delete:any"
      ],
      "admin": [
        "read:public",
        "read:private",
        "write:own",
        "write:any",
        "delete:own",
        "delete:any",
        "admin:access"
      ],
      "super_admin": [
        "read:public",
        "read:private",
        "write:own",
        "write:any",
        "delete:own",
        "delete:any",
        "admin:access",
        "super_admin:access"
      ]
    },
    "description": "Role-based access control configuration"
  },

  "csrf": {
    "enabled": true,
    "tokenLength": 64,
    "methods": ["POST", "PUT", "DELETE", "PATCH"],
    "description": "CSRF protection configuration"
  },

  "logging": {
    "securityEvents": true,
    "suspiciousActivity": true,
    "authFailures": true,
    "rateLimitExceeded": true,
    "validationFailures": true,
    "description": "Security event logging configuration"
  },

  "endpoints": {
    "public": [
      "/api/health",
      "/api/status",
      "/api/components",
      "/api/catalog"
    ],
    "protected": [
      "/api/agent-pages",
      "/api/agents",
      "/api/claude-code",
      "/api/feedback"
    ],
    "admin": [
      "/api/admin",
      "/api/security/report",
      "/api/users"
    ],
    "description": "Endpoint access control configuration"
  },

  "security": {
    "trustedProxies": [],
    "ipWhitelist": [],
    "ipBlacklist": [],
    "description": "IP filtering and proxy configuration"
  },

  "monitoring": {
    "enabled": true,
    "metricsEndpoint": "/api/metrics",
    "healthEndpoint": "/api/health",
    "description": "Monitoring and health check configuration"
  },

  "encryption": {
    "algorithm": "aes-256-gcm",
    "keyRotationDays": 90,
    "description": "Data encryption configuration"
  }
}
