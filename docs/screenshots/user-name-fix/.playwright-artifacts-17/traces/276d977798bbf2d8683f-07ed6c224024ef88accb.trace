f3f4f6;\n  margin: 0;\n}\n\n.connection-status .connected {\n  color: #10b981;\n  font-weight: 500;\n}\n\n.connection-status .disconnected {\n  color: #ef4444;\n  font-weight: 500;\n}\n\n.feed-filters {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  gap: 0.5rem;\n  padding: 1rem;\n  border-bottom: 1px solid #374151;\n  background: #111827;\n}\n\n.feed-filters button {\n  padding: 0.5rem 1rem;\n  border: 1px solid #374151;\n  background: #1f2937;\n  color: #9ca3af;\n  border-radius: 0.375rem;\n  cursor: pointer;\n  -webkit-transition: all 0.2s;\n  transition: all 0.2s;\n  font-size: 0.875rem;\n  font-weight: 500;\n}\n\n.feed-filters button:hover {\n  background: #374151;\n  color: #f3f4f6;\n}\n\n.feed-filters button.active {\n  background: #3b82f6;\n  color: white;\n  border-color: #3b82f6;\n  -webkit-box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);\n          box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);\n}\n\n.session-metrics {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 1rem;\n  padding: 1rem;\n  background: #111827;\n  border-bottom: 1px solid #374151;\n}\n\n.session-metrics .metric {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-orient: vertical;\n  -webkit-box-direction: normal;\n      -ms-flex-direction: column;\n          flex-direction: column;\n  gap: 0.25rem;\n}\n\n.session-metrics .label {\n  font-size: 0.75rem;\n  color: #6b7280;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  font-weight: 500;\n}\n\n.session-metrics .value {\n  font-size: 1.125rem;\n  font-weight: 600;\n  color: #f3f4f6;\n}\n\n.feed-events {\n  -webkit-box-flex: 1;\n      -ms-flex: 1;\n          flex: 1;\n  overflow-y: auto;\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-orient: vertical;\n  -webkit-box-direction: normal;\n      -ms-flex-direction: column;\n          flex-direction: column;\n  gap: 0.5rem;\n  padding: 1rem;\n}\n\n.feed-events::-webkit-scrollbar {\n  width: 8px;\n}\n\n.feed-events::-webkit-scrollbar-track {\n  background: #1f2937;\n  border-radius: 4px;\n}\n\n.feed-events::-webkit-scrollbar-thumb {\n  background: #374151;\n  border-radius: 4px;\n}\n\n.feed-events::-webkit-scrollbar-thumb:hover {\n  background: #4b5563;\n}\n\n.activity-event {\n  background: #111827;\n  border-radius: 0 0.375rem 0.375rem 0;\n  border-left: 3px solid #374151;\n  padding: 0.75rem;\n  -webkit-transition: all 0.2s;\n  transition: all 0.2s;\n}\n\n.activity-event:hover {\n  background: #1f2937;\n  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);\n          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);\n}\n\n.activity-event.high,\n.activity-event.critical {\n  border-left-color: #f59e0b;\n  background: #1f2514;\n}\n\n.activity-event.medium {\n  border-left-color: #eab308;\n}\n\n@-webkit-keyframes slideIn {\n  from {\n    opacity: 0;\n    -webkit-transform: translateX(-10px);\n            transform: translateX(-10px);\n  }\n  to {\n    opacity: 1;\n    -webkit-transform: translateX(0);\n            transform: translateX(0);\n  }\n}\n\n@keyframes slideIn {\n  from {\n    opacity: 0;\n    -webkit-transform: translateX(-10px);\n            transform: translateX(-10px);\n  }\n  to {\n    opacity: 1;\n    -webkit-transform: translateX(0);\n            transform: translateX(0);\n  }\n}\n\n.animate-slideIn {\n  -webkit-animation: slideIn 0.3s ease-out;\n          animation: slideIn 0.3s ease-out;\n}\n\n.event-icon {\n  font-size: 1.25rem;\n  -ms-flex-negative: 0;\n      flex-shrink: 0;\n}\n\n.event-content {\n  -webkit-box-flex: 1;\n      -ms-flex: 1;\n          flex: 1;\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-orient: vertical;\n  -webkit-box-direction: normal;\n      -ms-flex-direction: column;\n          flex-direction: column;\n  gap: 0.5rem;\n  min-width: 0;\n}\n\n.event-main {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  gap: 0.5rem;\n  -webkit-box-align: start;\n      -ms-flex-align: start;\n          align-items: flex-start;\n  -ms-flex-wrap: wrap;\n      flex-wrap: wrap;\n}\n\n.tool-name,\n.agent-type {\n  font-weight: 600;\n  color: #60a5fa;\n  font-size: 0.875rem;\n}\n\n.action {\n  color: #d1d5db;\n  font-family: 'Courier New', monospace;\n  font-size: 0.75rem;\n}\n\n.duration {\n  font-size: 0.75rem;\n  color: #9ca3af;\n  background: #374151;\n  padding: 0.125rem 0.5rem;\n  border-radius: 0.25rem;\n}\n\n.status {\n  font-size: 0.75rem;\n  padding: 0.125rem 0.625rem;\n  border-radius: 0.25rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  display: -webkit-inline-box;\n  display: -ms-inline-flexbox;\n  display: inline-flex;\n  -webkit-box-align: center;\n      -ms-flex-align: center;\n          align-items: center;\n  gap: 0.25rem;\n}\n\n.status.green,\n.text-green-400 {\n  color: #10b981;\n}\n\n.status.red,\n.text-red-400 {\n  color: #ef4444;\n}\n\n.status.blue,\n.text-blue-400 {\n  color: #60a5fa;\n}\n\n.event-error {\n  color: #f87171;\n  font-size: 0.75rem;\n  font-family: 'Courier New', monospace;\n  background: rgba(239, 68, 68, 0.1);\n  padding: 0.5rem;\n  border-radius: 0.25rem;\n}\n\n.event-meta {\n  font-size: 0.75rem;\n  color: #9ca3af;\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-align: center;\n      -ms-flex-align: center;\n          align-items: center;\n  gap: 0.25rem;\n}\n\n.event-progress {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-orient: vertical;\n  -webkit-box-direction: normal;\n      -ms-flex-direction: column;\n          flex-direction: column;\n  gap: 0.25rem;\n}\n\n.progress-bar {\n  height: 0.375rem;\n  background: #374151;\n  border-radius: 0.25rem;\n  overflow: hidden;\n}\n\n.progress-fill {\n  height: 100%;\n  background: #3b82f6;\n  -webkit-transition: width 0.3s ease;\n  transition: width 0.3s ease;\n  border-radius: 0.25rem;\n}\n\n.progress-text {\n  font-size: 0.75rem;\n  color: #9ca3af;\n  white-space: nowrap;\n}\n\n.event-time {\n  font-size: 0.75rem;\n  color: #6b7280;\n  font-family: 'Courier New', monospace;\n  white-space: nowrap;\n}\n\n.no-events {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  -webkit-box-orient: vertical;\n  -webkit-box-direction: normal;\n      -ms-flex-direction: column;\n          flex-direction: column;\n  -webkit-box-align: center;\n      -ms-flex-align: center;\n          align-items: center;\n  -webkit-box-pack: center;\n      -ms-flex-pack: center;\n          justify-content: center;\n  height: 100%;\n  color: #6b7280;\n  text-align: center;\n}\n\n/* Responsive adjustments */\n@media (max-width: 768px) {\n  .session-metrics {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .event-main {\n    -webkit-box-orient: vertical;\n    -webkit-box-direction: normal;\n        -ms-flex-direction: column;\n            flex-direction: column;\n  }\n\n  .feed-filters {\n    -ms-flex-wrap: wrap;\n        flex-wrap: wrap;\n  }\n}\n\n/* Dark mode support (already using dark colors, but add explicit dark: classes support) */\n@media (prefers-color-scheme: dark) {\n  .live-activity-feed {\n    background: #0f172a;\n  }\n\n  .feed-header,\n  .feed-filters,\n  .session-metrics {\n    border-color: #1e293b;\n  }\n}\n"],["STYLE",{},".PhotoView-Portal{direction:ltr;height:100%;left:0;overflow:hidden;position:fixed;top:0;-ms-touch-action:none;touch-action:none;width:100%;z-index:2000}@-webkit-keyframes PhotoView__rotate{0%{-webkit-transform:rotate(0deg);transform:rotate(0deg)}to{-webkit-transform:rotate(1turn);transform:rotate(1turn)}}@keyframes PhotoView__rotate{0%{-webkit-transform:rotate(0deg);transform:rotate(0deg)}to{-webkit-transform:rotate(1turn);transform:rotate(1turn)}}@-webkit-keyframes PhotoView__delayIn{0%,50%{opacity:0}to{opacity:1}}@keyframes PhotoView__delayIn{0%,50%{opacity:0}to{opacity:1}}.PhotoView__Spinner{-webkit-animation:PhotoView__delayIn .4s linear both;animation:PhotoView__delayIn .4s linea