rflow: hidden auto;\n  width: 1rem;\n  -ms-flex-negative: 0;\n      flex-shrink: 0;\n  /*firefox*/\n  scrollbar-width: thin;\n}\n._1eT-t::-webkit-scrollbar {\n  width: 1.1rem;\n  height: 1.1rem;\n}\n._1eT-t::-webkit-scrollbar-corner {\n  background: transparent;\n}\n._1eT-t::-webkit-scrollbar-thumb {\n  border: 6px solid transparent;\n  background: rgba(0, 0, 0, 0.2);\n  background: var(--palette-black-alpha-20, rgba(0, 0, 0, 0.2));\n  border-radius: 10px;\n  background-clip: padding-box;\n}\n._1eT-t::-webkit-scrollbar-thumb:hover {\n  border: 4px solid transparent;\n  background: rgba(0, 0, 0, 0.3);\n  background: var(--palette-black-alpha-30, rgba(0, 0, 0, 0.3));\n  background-clip: padding-box;\n}\n\n._2dZTy {\n  fill: #fff;\n}\n\n._2dZTy:nth-child(even) {\n  fill: #f5f5f5;\n}\n\n._3rUKi {\n  stroke: #ebeff2;\n}\n\n._RuwuK {\n  stroke: #e6e4e4;\n}\n\n._9w8d5 {\n  text-anchor: middle;\n  fill: #333;\n  -webkit-touch-callout: none;\n  -webkit-user-select: none;\n  -moz-user-select: none;\n  -ms-user-select: none;\n  user-select: none;\n  pointer-events: none;\n}\n\n._1rLuZ {\n  stroke: #e6e4e4;\n}\n\n._2q1Kt {\n  text-anchor: middle;\n  fill: #555;\n  -webkit-touch-callout: none;\n  -webkit-user-select: none;\n  -moz-user-select: none;\n  -ms-user-select: none;\n  user-select: none;\n  pointer-events: none;\n}\n\n._35nLX {\n  fill: #ffffff;\n  stroke: #e0e0e0;\n  stroke-width: 1.4;\n}\n\n._KxSXS {\n  cursor: pointer;\n  outline: none;\n}\n\n._KxSXS:hover ._3w_5u {\n  visibility: visible;\n  opacity: 1;\n}\n\n._3w_5u {\n  fill: #ddd;\n  cursor: ew-resize;\n  opacity: 0;\n  visibility: hidden;\n}\n\n._31ERP {\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n  stroke-width: 0;\n}\n\n._RRr13 {\n  cursor: pointer;\n  outline: none;\n}\n\n._2P2B1 {\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n}\n\n._1KJ6x {\n  cursor: pointer;\n  outline: none;\n}\n\n._2RbVy {\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n  opacity: 0.6;\n}\n\n._2pZMF {\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n}\n\n._3zRJQ {\n  fill: #fff;\n  text-anchor: middle;\n  font-weight: lighter;\n  dominant-baseline: central;\n  -webkit-touch-callout: none;\n  -webkit-user-select: none;\n  -moz-user-select: none;\n  -ms-user-select: none;\n  user-select: none;\n  pointer-events: none;\n}\n\n._3KcaM {\n  fill: #555;\n  text-anchor: start;\n  -webkit-touch-callout: none;\n  -webkit-user-select: none;\n  -moz-user-select: none;\n  -ms-user-select: none;\n  user-select: none;\n  pointer-events: none;\n}\n\n._CZjuD {\n  overflow: hidden;\n  font-size: 0;\n  margin: 0;\n  padding: 0;\n}\n\n._2B2zv {\n  margin: 0;\n  padding: 0;\n  overflow: hidden;\n}\n\n._3eULf {\n  display: -webkit-box;\n  display: -ms-flexbox;\n  display: flex;\n  padding: 0;\n  margin: 0;\n  list-style: none;\n  outline: none;\n  position: relative;\n}\n\n._2k9Ys {\n  overflow: auto;\n  max-width: 100%;\n  /*firefox*/\n  scrollbar-width: thin;\n  /*iPad*/\n  height: 1.2rem;\n}\n._2k9Ys::-webkit-scrollbar {\n  width: 1.1rem;\n  height: 1.1rem;\n}\n._2k9Ys::-webkit-scrollbar-corner {\n  background: transparent;\n}\n._2k9Ys::-webkit-scrollbar-thumb {\n  border: 6px solid transparent;\n  background: rgba(0, 0, 0, 0.2);\n  background: var(--palette-black-alpha-20, rgba(0, 0, 0, 0.2));\n  border-radius: 10px;\n  background-clip: padding-box;\n}\n._2k9Ys::-webkit-scrollbar-thumb:hover {\n  border: 4px solid transparent;\n  background: rgba(0, 0, 0, 0.3);\n  background: var(--palette-black-alpha-30, rgba(0, 0, 0, 0.3));\n  background-clip: padding-box;\n}\n@media only screen and (max-device-width: 1024px) and (-webkit-min-device-pixel-ratio: 2) {\n}\n._19jgW {\n  height: 1px;\n}\n"],["STYLE",{},"/* Import Markdown Styling */\n/**\n * Markdown Content Styling\n *\n * Comprehensive CSS for markdown rendering in Agent Feed\n * Based on SPARC Architecture: /workspaces/agent-feed/docs/SPARC-MARKDOWN-RENDERING-ARCHITECTURE.md\n *\n * Features:\n * - Typography hierarchy (h1-h6)\n * - Text formatting (bold, italic, code, strikethrough)\n * - Lists (ordered, unordered, task lists)\n * - Code blocks with syntax highlighting\n * - Blockquotes with left border\n * - Tables with borders and hover effects\n * - Links with hover states\n * - Horizontal rules\n * - Dark mode support\n * - Responsive design\n * - Accessibility compliant\n */\n/* ============================================\n   BASE CONTAINER\n   ============================================ */\n.markdown-content {\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content {\n  line-height: 1.625;\n  word-wrap: break-word;\n  overflow-wrap: break-word;\n  -ms-hyphens: auto;\n      hyphens: auto;\n  max-width: 100%;\n}\n/* ============================================\n   TYPOGRAPHY HIERARCHY\n   ============================================ */\n/* Heading 1 - Main title with bottom border */\n.markdown-content h1 {\n  margin-bottom: 1rem;\n  margin-top: 1.5rem;\n  font-size: 1.875rem;\n  line-height: 2.25rem;\n  font-weight: 700;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content h1:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content h1 {\n  border-bottom-width: 2px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n  padding-bottom: 0.5rem;\n}\n.markdown-content h1:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content h1 {\n  line-height: 1.25;\n  letter-spacing: -0.02em;\n}\n/* Heading 2 - Section title with bottom border */\n.markdown-content h2 {\n  margin-bottom: 0.75rem;\n  margin-top: 1.25rem;\n  font-size: 1.5rem;\n  line-height: 2rem;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content h2:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content h2 {\n  border-bottom-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n  padding-bottom: 0.25rem;\n}\n.markdown-content h2:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content h2 {\n  line-height: 1.3;\n  letter-spacing: -0.01em;\n}\n/* Heading 3 - Subsection title */\n.markdown-content h3 {\n  margin-bottom: 0.5rem;\n  margin-top: 1rem;\n  font-size: 1.25rem;\n  line-height: 1.75rem;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(31 41 55 / var(--tw-text-opacity, 1));\n}\n.markdown-content h3:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(229 231 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content h3 {\n  line-height: 1.4;\n}\n/* Heading 4 */\n.markdown-content h4 {\n  margin-bottom: 0.5rem;\n  margin-top: 0.75rem;\n  font-size: 1.125rem;\n  line-height: 1.75rem;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(31 41 55 / var(--tw-text-opacity, 1));\n}\n.markdown-content h4:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(229 231 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content h4 {\n  line-height: 1.4;\n}\n/* Heading 5 and 6 */\n.markdown-content h5,\n.markdown-content h6 {\n  margin-bottom: 0.5rem;\n  margin-top: 0.75rem;\n  font-size: 1rem;\n  line-height: 1.5rem;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content h5:is(.dark *),\n.markdown-content h6:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n.markdown-content h5,\n.markdown-content h6 {\n  line-height: 1.5;\n}\n/* First heading should not have top margin */\n.markdown-content > h1:first-child,\n.markdown-content > h2:first-child,\n.markdown-content > h3:first-child,\n.markdown-content > h4:first-child,\n.markdown-content > h5:first-child,\n.markdown-content > h6:first-child {\n  margin-top: 0px;\n}\n/* ============================================\n   PARAGRAPHS\n   ============================================ */\n.markdown-content p {\n  margin-bottom: 1rem;\n  line-height: 1.625;\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content p:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n.markdown-content p {\n  line-height: 1.7;\n}\n.markdown-content p:last-child {\n  margin-bottom: 0px;\n}\n/* ============================================\n   TEXT FORMATTING\n   ============================================ */\n/* Bold text */\n.markdown-content strong,\n.markdown-content b {\n  font-weight: 700;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content strong:is(.dark *),\n.markdown-content b:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n/* Italic text */\n.markdown-content em,\n.markdown-content i {\n  font-style: italic;\n}\n/* Strikethrough (GFM) */\n.markdown-content del,\n.markdown-content s {\n  --tw-text-opacity: 1;\n  color: rgb(107 114 128 / var(--tw-text-opacity, 1));\n}\n.markdown-content del:is(.dark *),\n.markdown-content s:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\n.markdown-content del,\n.markdown-content s {\n  text-decoration-line: line-through;\n  opacity: 0.8;\n}\n/* Underline */\n.markdown-content u {\n  text-decoration-line: underline;\n  text-decoration-color: #9ca3af;\n}\n.markdown-content u:is(.dark *) {\n  text-decoration-color: #4b5563;\n}\n.markdown-content u {\n  text-underline-offset: 2px;\n}\n/* Inserted text */\n.markdown-content ins {\n  --tw-bg-opacity: 1;\n  background-color: rgb(220 252 231 / var(--tw-bg-opacity, 1));\n}\n.markdown-content ins:is(.dark *) {\n  background-color: rgb(20 83 45 / 0.3);\n}\n.markdown-content ins {\n  --tw-text-opacity: 1;\n  color: rgb(20 83 45 / var(--tw-text-opacity, 1));\n}\n.markdown-content ins:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(220 252 231 / var(--tw-text-opacity, 1));\n}\n.markdown-content ins {\n  padding-left: 0.25rem;\n  padding-right: 0.25rem;\n  text-decoration-line: none;\n}\n/* ============================================\n   LINKS\n   ============================================ */\n.markdown-content a {\n  --tw-text-opacity: 1;\n  color: rgb(37 99 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content a:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(96 165 250 / var(--tw-text-opacity, 1));\n}\n.markdown-content a:hover {\n  --tw-text-opacity: 1;\n  color: rgb(30 64 175 / var(--tw-text-opacity, 1));\n}\n.markdown-content a:hover:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(147 197 253 / var(--tw-text-opacity, 1));\n}\n.markdown-content a {\n  text-decoration-line: underline;\n  text-decoration-color: #93c5fd;\n}\n.markdown-content a:is(.dark *) {\n  text-decoration-color: #1d4ed8;\n}\n.markdown-content a {\n  -webkit-transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  -webkit-transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n          transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  -webkit-transition-duration: 200ms;\n          transition-duration: 200ms;\n  word-break: break-word;\n}\n.markdown-content a:visited {\n  --tw-text-opacity: 1;\n  color: rgb(147 51 234 / var(--tw-text-opacity, 1));\n}\n.markdown-content a:visited:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(192 132 252 / var(--tw-text-opacity, 1));\n}\n.markdown-content a:hover {\n  text-decoration-color: #3b82f6;\n}\n.markdown-content a:hover:is(.dark *) {\n  text-decoration-color: #3b82f6;\n}\n/* External link indicator */\n.markdown-content a[target=\"_blank\"]::after {\n  content: \" ↗\";\n  font-size: 0.75rem;\n  line-height: 1rem;\n  opacity: 0.6;\n  margin-left: 2px;\n}\n/* ============================================\n   LISTS\n   ============================================ */\n.markdown-content ul,\n.markdown-content ol {\n  margin-bottom: 1rem;\n  margin-left: 1.5rem;\n}\n.markdown-content ul > :not([hidden]) ~ :not([hidden]),\n.markdown-content ol > :not([hidden]) ~ :not([hidden]) {\n  --tw-space-y-reverse: 0;\n  margin-top: calc(0.5rem * calc(1 - var(--tw-space-y-reverse)));\n  margin-bottom: calc(0.5rem * var(--tw-space-y-reverse));\n}\n.markdown-content ul,\n.markdown-content ol {\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content ul:is(.dark *),\n.markdown-content ol:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n.markdown-content ul,\n.markdown-content ol {\n  line-height: 1.7;\n}\n.markdown-content ul {\n  list-style-type: disc;\n}\n.markdown-content ol {\n  list-style-type: decimal;\n}\n.markdown-content li {\n  line-height: 1.625;\n  padding-left: 0.5rem;\n}\n.markdown-content li > p {\n  margin-bottom: 0.5rem;\n  margin-top: 0.5rem;\n}\n.markdown-content li > p:first-child {\n  margin-top: 0px;\n}\n.markdown-content li > p:last-child {\n  margin-bottom: 0px;\n}\n/* Nested lists */\n.markdown-content ul ul,\n.markdown-content ol ul,\n.markdown-content ul ol,\n.markdown-content ol ol {\n  margin-top: 0.5rem;\n  margin-bottom: 0.5rem;\n  margin-left: 1.5rem;\n}\n/* Task Lists (GFM) */\n.markdown-content .task-list-item {\n  list-style-type: none;\n  margin-left: -1.5rem;\n}\n.markdown-content .task-list-item input[type=\"checkbox\"] {\n  margin-right: 0.5rem;\n  cursor: pointer;\n  height: 1rem;\n  width: 1rem;\n  vertical-align: middle;\n  accent-color: #2563eb;\n}\n.markdown-content .task-list-item input[type=\"checkbox\"]:is(.dark *) {\n  accent-color: #3b82f6;\n}\n.markdown-content .task-list-item input[type=\"checkbox\"] {\n  vertical-align: text-bottom;\n}\n.markdown-content .task-list-item input[type=\"checkbox\"]:checked {\n  accent-color: #16a34a;\n}\n.markdown-content .task-list-item input[type=\"checkbox\"]:checked:is(.dark *) {\n  accent-color: #22c55e;\n}\n/* ============================================\n   CODE - INLINE\n   ============================================ */\n.markdown-content code {\n  border-radius: 0.25rem;\n  padding-left: 0.375rem;\n  padding-right: 0.375rem;\n  padding-top: 0.125rem;\n  padding-bottom: 0.125rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(243 244 246 / var(--tw-bg-opacity, 1));\n}\n.markdown-content code:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1));\n}\n.markdown-content code {\n  --tw-text-opacity: 1;\n  color: rgb(219 39 119 / var(--tw-text-opacity, 1));\n}\n.markdown-content code:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(244 114 182 / var(--tw-text-opacity, 1));\n}\n.markdown-content code {\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content code:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content code {\n  white-space: pre-wrap;\n  word-break: break-word;\n}\n/* Remove inline code styling from code blocks */\n.markdown-content pre code {\n  border-width: 0px;\n  background-color: transparent;\n  padding: 0px;\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n  white-space: pre;\n}\n/* ============================================\n   CODE - BLOCKS\n   ============================================ */\n.markdown-content pre {\n  margin-bottom: 1rem;\n  overflow-x: auto;\n  border-radius: 0.5rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(17 24 39 / var(--tw-bg-opacity, 1));\n}\n.markdown-content pre:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(3 7 18 / var(--tw-bg-opacity, 1));\n}\n.markdown-content pre {\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);\n          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);\n}\n.markdown-content pre code {\n  display: block;\n  padding: 1rem;\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n  font-family: 'Consolas', 'Monaco', 'Courier New', 'Andale Mono', 'Ubuntu Mono', monospace;\n  tab-size: 2;\n  -moz-tab-size: 2;\n  line-height: 1.6;\n}\n/* Code block with language label */\n.markdown-content pre[data-language]::before {\n  content: attr(data-language);\n  position: absolute;\n  top: 0.5rem;\n  right: 0.5rem;\n  font-size: 0.75rem;\n  line-height: 1rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n  border-radius: 0.25rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1));\n  padding-left: 0.5rem;\n  padding-right: 0.5rem;\n  padding-top: 0.25rem;\n  padding-bottom: 0.25rem;\n  z-index: 1;\n}\n/* ============================================\n   SYNTAX HIGHLIGHTING (highlight.js)\n   ============================================ */\n.markdown-content .hljs {\n  --tw-bg-opacity: 1;\n  background-color: rgb(17 24 39 / var(--tw-bg-opacity, 1));\n}\n.markdown-content .hljs:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(3 7 18 / var(--tw-bg-opacity, 1));\n}\n.markdown-content .hljs {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-keyword {\n  --tw-text-opacity: 1;\n  color: rgb(192 132 252 / var(--tw-text-opacity, 1));\n  font-weight: 600;\n}\n.markdown-content .hljs-string {\n  --tw-text-opacity: 1;\n  color: rgb(74 222 128 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-number {\n  --tw-text-opacity: 1;\n  color: rgb(251 146 60 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-comment {\n  font-style: italic;\n  --tw-text-opacity: 1;\n  color: rgb(107 114 128 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-function {\n  --tw-text-opacity: 1;\n  color: rgb(96 165 250 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-class {\n  --tw-text-opacity: 1;\n  color: rgb(250 204 21 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-title {\n  --tw-text-opacity: 1;\n  color: rgb(147 197 253 / var(--tw-text-opacity, 1));\n  font-weight: 600;\n}\n.markdown-content .hljs-variable {\n  --tw-text-opacity: 1;\n  color: rgb(34 211 238 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-attribute {\n  --tw-text-opacity: 1;\n  color: rgb(253 186 116 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-built_in {\n  --tw-text-opacity: 1;\n  color: rgb(253 224 71 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-operator {\n  --tw-text-opacity: 1;\n  color: rgb(244 114 182 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-selector-tag {\n  --tw-text-opacity: 1;\n  color: rgb(216 180 254 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-selector-class,\n.markdown-content .hljs-selector-id {\n  --tw-text-opacity: 1;\n  color: rgb(147 197 253 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-tag {\n  --tw-text-opacity: 1;\n  color: rgb(192 132 252 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-name {\n  --tw-text-opacity: 1;\n  color: rgb(96 165 250 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-meta {\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-literal {\n  --tw-text-opacity: 1;\n  color: rgb(45 212 191 / var(--tw-text-opacity, 1));\n}\n.markdown-content .hljs-regexp {\n  --tw-text-opacity: 1;\n  color: rgb(248 113 113 / var(--tw-text-opacity, 1));\n}\n/* ============================================\n   BLOCKQUOTES\n   ============================================ */\n.markdown-content blockquote {\n  margin-top: 1rem;\n  margin-bottom: 1rem;\n  border-left-width: 4px;\n  --tw-border-opacity: 1;\n  border-color: rgb(59 130 246 / var(--tw-border-opacity, 1));\n  padding-top: 0.5rem;\n  padding-bottom: 0.5rem;\n  padding-left: 1rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(239 246 255 / var(--tw-bg-opacity, 1));\n}\n.markdown-content blockquote:is(.dark *) {\n  background-color: rgb(30 58 138 / 0.2);\n}\n.markdown-content blockquote {\n  font-style: italic;\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content blockquote:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n.markdown-content blockquote {\n  border-radius: 0 0.25rem 0.25rem 0;\n}\n.markdown-content blockquote p {\n  margin-bottom: 0.5rem;\n}\n.markdown-content blockquote p:last-child {\n  margin-bottom: 0px;\n}\n.markdown-content blockquote p:first-child {\n  margin-top: 0px;\n}\n/* Nested blockquotes */\n.markdown-content blockquote blockquote {\n  margin-top: 0.5rem;\n  margin-bottom: 0.5rem;\n  border-left-width: 4px;\n  --tw-border-opacity: 1;\n  border-color: rgb(156 163 175 / var(--tw-border-opacity, 1));\n}\n.markdown-content blockquote blockquote:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(75 85 99 / var(--tw-border-opacity, 1));\n}\n.markdown-content blockquote blockquote {\n  --tw-bg-opacity: 1;\n  background-color: rgb(243 244 246 / var(--tw-bg-opacity, 1));\n}\n.markdown-content blockquote blockquote:is(.dark *) {\n  background-color: rgb(31 41 55 / 0.3);\n}\n/* ============================================\n   TABLES\n   ============================================ */\n.markdown-content table {\n  margin-bottom: 1rem;\n  width: 100%;\n  border-collapse: collapse;\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content table:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content table {\n  border-radius: 0.5rem;\n  overflow: hidden;\n}\n.markdown-content thead {\n  --tw-bg-opacity: 1;\n  background-color: rgb(249 250 251 / var(--tw-bg-opacity, 1));\n}\n.markdown-content thead:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1));\n}\n.markdown-content th {\n  padding-left: 1rem;\n  padding-right: 1rem;\n  padding-top: 0.5rem;\n  padding-bottom: 0.5rem;\n  text-align: left;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content th:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content th {\n  border-bottom-width: 2px;\n  --tw-border-opacity: 1;\n  border-color: rgb(209 213 219 / var(--tw-border-opacity, 1));\n}\n.markdown-content th:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(75 85 99 / var(--tw-border-opacity, 1));\n}\n.markdown-content th {\n  white-space: nowrap;\n}\n.markdown-content td {\n  padding-left: 1rem;\n  padding-right: 1rem;\n  padding-top: 0.5rem;\n  padding-bottom: 0.5rem;\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content td:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n.markdown-content td {\n  border-bottom-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content td:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content tr:last-child td {\n  border-bottom-width: 0px;\n}\n.markdown-content tbody tr:hover {\n  --tw-bg-opacity: 1;\n  background-color: rgb(249 250 251 / var(--tw-bg-opacity, 1));\n}\n.markdown-content tbody tr:hover:is(.dark *) {\n  background-color: rgb(31 41 55 / 0.5);\n}\n.markdown-content tbody tr:hover {\n  -webkit-transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  -webkit-transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n          transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  -webkit-transition-duration: 150ms;\n          transition-duration: 150ms;\n}\n/* Table wrapper for horizontal scrolling */\n.markdown-content table-wrapper {\n  margin-top: 1rem;\n  margin-bottom: 1rem;\n  overflow-x: auto;\n  -webkit-overflow-scrolling: touch;\n}\n/* Alternating row colors */\n.markdown-content tbody tr:nth-child(even) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(249 250 251 / var(--tw-bg-opacity, 1));\n}\n.markdown-content tbody tr:nth-child(even):is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1));\n}\n/* ============================================\n   HORIZONTAL RULES\n   ============================================ */\n.markdown-content hr {\n  margin-top: 2rem;\n  margin-bottom: 2rem;\n  border-width: 0px;\n  border-top-width: 2px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content hr:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content hr {\n  width: 100%;\n}\n/* ============================================\n   IMAGES\n   ============================================ */\n.markdown-content img {\n  height: auto;\n  max-width: 100%;\n  border-radius: 0.5rem;\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content img:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content img {\n  margin-top: 1rem;\n  margin-bottom: 1rem;\n  -webkit-box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);\n          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);\n}\n.markdown-content img[alt] {\n  cursor: help;\n}\n/* Image captions */\n.markdown-content img + em {\n  display: block;\n  text-align: center;\n  font-size: 0.875rem;\n  line-height: 1.25rem;\n  --tw-text-opacity: 1;\n  color: rgb(75 85 99 / var(--tw-text-opacity, 1));\n}\n.markdown-content img + em:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(156 163 175 / var(--tw-text-opacity, 1));\n}\n.markdown-content img + em {\n  margin-top: 0.5rem;\n  margin-bottom: 1rem;\n  font-style: normal;\n}\n/* ============================================\n   DEFINITION LISTS\n   ============================================ */\n.markdown-content dl {\n  margin-bottom: 1rem;\n}\n.markdown-content dt {\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content dt:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content dt {\n  margin-top: 1rem;\n  margin-bottom: 0.25rem;\n}\n.markdown-content dd {\n  margin-left: 1.5rem;\n  margin-bottom: 0.5rem;\n  --tw-text-opacity: 1;\n  color: rgb(55 65 81 / var(--tw-text-opacity, 1));\n}\n.markdown-content dd:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(209 213 219 / var(--tw-text-opacity, 1));\n}\n/* ============================================\n   ABBREVIATIONS\n   ============================================ */\n.markdown-content abbr[title] {\n  border-bottom-width: 2px;\n  border-style: dotted;\n  --tw-border-opacity: 1;\n  border-color: rgb(156 163 175 / var(--tw-border-opacity, 1));\n}\n.markdown-content abbr[title]:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(75 85 99 / var(--tw-border-opacity, 1));\n}\n.markdown-content abbr[title] {\n  cursor: help;\n  text-decoration: none;\n}\n/* ============================================\n   KEYBOARD INPUT\n   ============================================ */\n.markdown-content kbd {\n  border-radius: 0.25rem;\n  padding-left: 0.5rem;\n  padding-right: 0.5rem;\n  padding-top: 0.25rem;\n  padding-bottom: 0.25rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(229 231 235 / var(--tw-bg-opacity, 1));\n}\n.markdown-content kbd:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(55 65 81 / var(--tw-bg-opacity, 1));\n}\n.markdown-content kbd {\n  --tw-text-opacity: 1;\n  color: rgb(31 41 55 / var(--tw-text-opacity, 1));\n}\n.markdown-content kbd:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(229 231 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content kbd {\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace;\n  font-size: 0.75rem;\n  line-height: 1rem;\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(156 163 175 / var(--tw-border-opacity, 1));\n}\n.markdown-content kbd:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(75 85 99 / var(--tw-border-opacity, 1));\n}\n.markdown-content kbd {\n  -webkit-box-shadow: 0 2px 0 rgba(0, 0, 0, 0.2);\n          box-shadow: 0 2px 0 rgba(0, 0, 0, 0.2);\n  display: inline-block;\n}\n/* ============================================\n   SUBSCRIPT & SUPERSCRIPT\n   ============================================ */\n.markdown-content sub,\n.markdown-content sup {\n  font-size: 0.75rem;\n  line-height: 1rem;\n  line-height: 0;\n  position: relative;\n  vertical-align: baseline;\n}\n.markdown-content sup {\n  top: -0.5em;\n}\n.markdown-content sub {\n  bottom: -0.25em;\n}\n/* ============================================\n   MARK / HIGHLIGHT\n   ============================================ */\n.markdown-content mark {\n  --tw-bg-opacity: 1;\n  background-color: rgb(254 240 138 / var(--tw-bg-opacity, 1));\n}\n.markdown-content mark:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(161 98 7 / var(--tw-bg-opacity, 1));\n}\n.markdown-content mark {\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content mark:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content mark {\n  border-radius: 0.25rem;\n  padding-left: 0.25rem;\n  padding-right: 0.25rem;\n}\n/* ============================================\n   DETAILS / SUMMARY\n   ============================================ */\n.markdown-content details {\n  margin-bottom: 1rem;\n  border-radius: 0.5rem;\n  padding: 1rem;\n  --tw-bg-opacity: 1;\n  background-color: rgb(249 250 251 / var(--tw-bg-opacity, 1));\n}\n.markdown-content details:is(.dark *) {\n  --tw-bg-opacity: 1;\n  background-color: rgb(31 41 55 / var(--tw-bg-opacity, 1));\n}\n.markdown-content details {\n  border-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content details:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n.markdown-content summary {\n  cursor: pointer;\n  font-weight: 600;\n  --tw-text-opacity: 1;\n  color: rgb(17 24 39 / var(--tw-text-opacity, 1));\n}\n.markdown-content summary:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(243 244 246 / var(--tw-text-opacity, 1));\n}\n.markdown-content summary:hover {\n  --tw-text-opacity: 1;\n  color: rgb(37 99 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content summary:hover:is(.dark *) {\n  --tw-text-opacity: 1;\n  color: rgb(96 165 250 / var(--tw-text-opacity, 1));\n}\n.markdown-content summary {\n  -webkit-transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;\n  -webkit-transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n          transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);\n  -webkit-transition-duration: 200ms;\n          transition-duration: 200ms;\n  -webkit-user-select: none;\n     -moz-user-select: none;\n      -ms-user-select: none;\n          user-select: none;\n}\n.markdown-content summary::-webkit-details-marker {\n  --tw-text-opacity: 1;\n  color: rgb(37 99 235 / var(--tw-text-opacity, 1));\n}\n.markdown-content summary:is(.dark *)::-webkit-details-marker {\n  --tw-text-opacity: 1;\n  color: rgb(96 165 250 / var(--tw-text-opacity, 1));\n}\n.markdown-content details[open] summary {\n  margin-bottom: 0.75rem;\n  padding-bottom: 0.5rem;\n  border-bottom-width: 1px;\n  --tw-border-opacity: 1;\n  border-color: rgb(229 231 235 / var(--tw-border-opacity, 1));\n}\n.markdown-content details[open] summary:is(.dark *) {\n  --tw-border-opacity: 1;\n  border-color: rgb(55 65 81 / var(--tw-border-opacity, 1));\n}\n/* ============================================\n   RESPONSIVE DESIGN\n   ============================================ */\n@media (max-width: 768px) {\n  /* Reduce heading sizes on mobile */\n  .markdown-content h1 {\n    font-size: 1.5rem;\n    line-height: 2rem;\n  }\n\n  .markdown-content h2 {\n    font-size: 1.25rem;\n    line-height: 1.75rem;\n  }\n\n  .markdown-content h3 {\n    font-size: 1.125rem;\n    line-height: 1.75rem;\n  }\n\n  .markdown-content h4,\n  .markdown-content h5,\n  .markdown-content h6 {\n    font-size: 1rem;\n    line-height: 1.5rem;\n  }\n\n  /* Smaller table text on mobile */\n  .markdown-content table {\n    font-size: 0.875rem;\n    line-height: 1.25rem;\n  }\n\n  .markdown-content th,\n  .markdown-content td {\n 