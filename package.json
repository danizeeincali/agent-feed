{
  "name": "agent-feed",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node simple-backend.js",
    "build": "cd frontend && npm run build",
    "build:backend": "echo 'Backend is plain JS - no build needed'",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd frontend && npm run preview",
    "start:backend": "node simple-backend.js",
    "test:validate": "node tests/test-validation-runner.js",
    "test:all": "./tests/run-all-tests.sh",
    "test:health": "jest --config jest.config.cjs tests/health",
    "test:unit": "jest",
    "test:integration": "jest --config=jest.integration.config.js",
    "test:e2e": "playwright test",
    "test:regression": "jest --config jest.config.cjs tests/regression",
    "test:coverage": "jest --coverage",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:e2e:performance": "playwright test --grep=\"Performance|Load|Memory\"",
    "test:e2e:visual": "playwright test --grep=\"Visual|Loading.*Animation|Screenshot\"",
    "test:e2e:report": "playwright show-report tests/e2e/reports/html",
    "test:websocket": "jest --config tests/websocket/jest.config.js",
    "test:websocket:unit": "jest --config tests/websocket/jest.config.js --testPathPattern=unit",
    "test:websocket:integration": "jest --config tests/websocket/jest.config.js --testPathPattern=integration",
    "test:websocket:load": "jest --config tests/websocket/jest.config.js --testPathPattern=load",
    "test:websocket:regression": "jest --config tests/websocket/jest.config.js --testPathPattern=regression",
    "test:websocket:performance": "jest --config tests/websocket/jest.config.js --testPathPattern=performance",
    "test:websocket:e2e": "cd tests/websocket && npx playwright test",
    "test:websocket:coverage": "jest --config tests/websocket/jest.config.js --coverage",
    "test:websocket:all": "npm run test:websocket:coverage && npm run test:websocket:e2e",
    "test:tdd-claude-api": "jest --config tests/tdd-claude-api/jest.config.js",
    "test:tdd-claude-api:unit": "jest --config tests/tdd-claude-api/jest.config.js --testPathPattern=unit",
    "test:tdd-claude-api:integration": "jest --config tests/tdd-claude-api/jest.config.js --testPathPattern=integration",
    "test:tdd-claude-api:performance": "jest --config tests/tdd-claude-api/jest.config.js --testPathPattern=performance",
    "test:tdd-claude-api:coverage": "jest --config tests/tdd-claude-api/jest.config.js --coverage",
    "test:tdd-claude-api:watch": "jest --config tests/tdd-claude-api/jest.config.js --watch",
    "test:london-school": "jest --config tests/tdd-london-school/jest.config.js",
    "test:contracts": "jest tests/tdd-london-school/instance-lifecycle/component-behavior-contracts.test.ts",
    "test:leaks": "jest tests/tdd-london-school/instance-lifecycle/resource-leak-prevention.test.ts",
    "test:interactions": "jest tests/tdd-london-school/instance-lifecycle/interaction-verification.test.ts",
    "test:lifecycle": "jest tests/tdd-london-school/instance-lifecycle/claude-instance-lifecycle.test.ts",
    "test:tdd-all": "npm run test:london-school && npm run test:contracts && npm run test:leaks",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "agentlink:start": "./scripts/start-agentlink.sh",
    "agentlink:stop": "./scripts/stop-agentlink.sh",
    "agentlink:status": "./scripts/status-agentlink.sh",
    "test:performance": "node monitoring/tests/claude-response-latency.test.js",
    "test:sse": "node monitoring/tests/sse-delivery-performance.test.js",
    "load-test": "node scripts/load-testing/concurrent-users.js",
    "load-test:basic": "node scripts/load-testing/concurrent-users.js basic_load 5 60000",
    "load-test:stress": "node scripts/load-testing/concurrent-users.js stress_test 10 120000",
    "load-test:all": "node scripts/load-testing/concurrent-users.js all 10 180000",
    "performance-gates": "node scripts/ci-cd/performance-gates.js",
    "performance-gates:smoke": "node scripts/ci-cd/performance-gates.js --smoke-only",
    "performance-gates:config": "node scripts/ci-cd/performance-gates.js --config=ci-config/performance-gates.json",
    "benchmark": "npm run test:performance && npm run test:sse",
    "monitor": "node monitoring/performance-benchmarks.js",
    "dashboard": "open monitoring/dashboards/performance-metrics.html",
    "ci:performance": "npm run performance-gates --config=ci-config/performance-gates.json",
    "precommit": "npm run lint && npm run test:unit && npm run performance-gates:smoke"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chart.js": "^4.4.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.21",
    "node-pty": "^1.0.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.16.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "@playwright/test": "^1.55.0",
    "@puppeteer/browsers": "^2.10.8",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.5.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.2",
    "@types/websocket": "^1.0.10",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "artillery": "^2.0.3",
    "axios": "^1.11.0",
    "chai": "^6.0.1",
    "clinic": "^13.0.0",
    "eslint": "^8.47.0",
    "eventsource": "^4.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "lighthouse": "^12.8.2",
    "mocha": "^11.7.2",
    "node-fetch": "^3.3.2",
    "playwright": "^1.55.0",
    "puppeteer": "^24.19.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "websocket": "^1.0.35",
    "ws": "^8.18.3"
  }
}
