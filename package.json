{
  "name": "agent-feed",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"cd api-server && npm run dev\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm run build",
    "start": "concurrently \"cd api-server && npm start\" \"cd frontend && npm run preview\"",
    "lint": "cd frontend && npm run lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:showcase": "playwright test frontend/tests/e2e/component-showcase",
    "test:showcase:ui": "playwright test frontend/tests/e2e/component-showcase --ui",
    "test:showcase:headed": "playwright test frontend/tests/e2e/component-showcase --headed",
    "test:showcase:debug": "playwright test frontend/tests/e2e/component-showcase --debug",
    "test:showcase:chromium": "playwright test frontend/tests/e2e/component-showcase --project=chromium",
    "test:showcase:firefox": "playwright test frontend/tests/e2e/component-showcase --project=firefox",
    "test:showcase:webkit": "playwright test frontend/tests/e2e/component-showcase --project=webkit",
    "test:showcase:mobile": "playwright test frontend/tests/e2e/component-showcase --project='Mobile Chrome'",
    "test:showcase:snapshots": "playwright test frontend/tests/e2e/component-showcase --update-snapshots",
    "test:performance": "node tests/performance/performance-runner.js",
    "test:performance:lighthouse": "lhci autorun --config=tests/performance/lighthouse-config.js",
    "test:performance:bundle": "node tests/performance/bundle-analyzer.js",
    "test:performance:memory": "node tests/performance/memory-leak-detector.js",
    "test:performance:api": "playwright test tests/performance/api-performance.spec.ts",
    "test:performance:interaction": "node tests/performance/user-interaction-metrics.js",
    "performance:baseline": "UPDATE_BASELINE=true npm run test:performance",
    "ci:performance": "npm run test:performance -- --no-browser",
    "analyze:bundle": "ANALYZE=true npm run build",
    "bundle:report": "webpack-bundle-analyzer .next/static/chunks/webpack-*.js",
    "test:token-analytics": "node tests/token-analytics/run-all-tests.js",
    "test:token-analytics:unit": "jest --config tests/token-analytics/jest.config.js",
    "test:token-analytics:integration": "jest tests/token-analytics/integration/api-integration.test.js",
    "test:token-analytics:e2e": "playwright test --config tests/token-analytics/e2e/playwright.config.js",
    "test:token-analytics:regression": "jest tests/token-analytics/regression/fake-data-prevention.test.js",
    "test:regression": "node tests/regression/run-regression-suite.js",
    "test:regression:jest": "jest --config tests/regression/jest.config.regression.js",
    "test:regression:playwright": "playwright test --config tests/regression/playwright.config.regression.js",
    "test:tdd": "jest --config jest.tdd.config.js",
    "test:tdd:watch": "jest --config jest.tdd.config.js --watch",
    "test:tdd:coverage": "jest --config jest.tdd.config.js --coverage",
    "test:tdd:api": "jest --config jest.tdd.config.js --selectProjects=\"API Server Tests\"",
    "test:tdd:integration": "jest --config jest.tdd.config.js --selectProjects=\"Integration Tests\"",
    "test:tdd:contracts": "jest --config jest.tdd.config.js --selectProjects=\"Contract Tests\"",
    "test:tdd:errors": "jest --config jest.tdd.config.js --selectProjects=\"Error Scenario Tests\"",
    "test:tdd:e2e": "jest --config jest.tdd.config.js --selectProjects=\"E2E Tests\"",
    "test:tdd:real-api": "TEST_REAL_API=true jest --config jest.tdd.config.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.113",
    "@anthropic-ai/sdk": "^0.62.0",
    "@instantlyeasy/claude-code-sdk-ts": "^0.3.3",
    "@tanstack/react-query": "^5.90.2",
    "better-sqlite3": "^12.2.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cheerio": "^1.1.2",
    "claude-code-js": "^0.4.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "framer-motion": "^12.23.19",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.0.0",
    "lucide-react": "^0.544.0",
    "node-pty": "^1.0.0",
    "react": "18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^7.9.3",
    "socket.io-client": "^4.8.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@lhci/cli": "^0.12.0",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/jest": "^30.0.0",
    "@types/node": "20.0.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.2.0",
    "concurrently": "^7.6.0",
    "critters": "^0.0.25",
    "eslint": "8.0.0",
    "eventsource": "^4.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "lighthouse": "^11.0.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.55.1",
    "postcss": "^8.5.6",
    "postcss-nesting": "^13.0.2",
    "puppeteer": "^21.11.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.2",
    "typescript": "5.9.2",
    "webpack-bundle-analyzer": "^4.9.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/.next/",
      "<rootDir>/node_modules/",
      "<rootDir>/tests/performance/"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
