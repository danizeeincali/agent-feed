{
  "name": "agent-feed",
  "version": "1.0.0",
  "description": "Enterprise Agent Feed System with Claude-Flow Integration",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:terminal": "node backend-terminal-server-robust.js",
    "build": "tsc && tsc-alias",
    "start": "node dist/api/server.js",
    "start:terminal": "node backend-terminal-server-robust.js",
    "migrate": "tsx src/database/migrate.ts",
    "seed": "tsx src/database/seed.ts",
    "test": "jest",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "npx playwright test --ui",
    "test:white-screen": "npx playwright test frontend/tests/white-screen-detection",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:http-500-errors": "npm run test:http-500-backend && npm run test:http-500-e2e",
    "test:http-500-backend": "jest --config tests/http-500-error/jest.config.js",
    "test:http-500-e2e": "npx playwright test --config tests/http-500-error/playwright.config.ts",
    "test:http-500-coverage": "jest --config tests/http-500-error/jest.config.js --coverage",
    "test:http-500-debug": "DEBUG=1 jest --config tests/http-500-error/jest.config.js --verbose",
    "test:http-500-watch": "jest --config tests/http-500-error/jest.config.js --watch",
    "test:websocket": "jest --config tests/websocket/jest.config.js",
    "test:websocket:unit": "jest --config tests/websocket/jest.config.js --testPathPattern=unit",
    "test:websocket:integration": "jest --config tests/websocket/jest.config.js --testPathPattern=integration",
    "test:websocket:load": "jest --config tests/websocket/jest.config.js --testPathPattern=load",
    "test:websocket:regression": "jest --config tests/websocket/jest.config.js --testPathPattern=regression",
    "test:websocket:performance": "jest --config tests/websocket/jest.config.js --testPathPattern=performance",
    "test:websocket:e2e": "cd tests/websocket && npx playwright test",
    "test:websocket:coverage": "jest --config tests/websocket/jest.config.js --coverage",
    "test:websocket:all": "npm run test:websocket:coverage && npm run test:websocket:e2e",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "agentlink:start": "./scripts/start-agentlink.sh",
    "agentlink:stop": "./scripts/stop-agentlink.sh",
    "agentlink:status": "./scripts/status-agentlink.sh",
    "agentlink:logs": "tail -f logs/backend.log logs/frontend.log",
    "test:build-validation": "jest tests/regression/build-validation.test.ts",
    "test:cors-validation": "jest tests/regression/cors-validation.test.ts",
    "test:terminal-integration": "jest tests/regression/terminal-integration.test.js",
    "test:terminal-e2e": "cd frontend && npm run test:e2e -- tests/regression/terminal-e2e.test.ts",
    "regression:health-monitor": "node scripts/health-monitor.js",
    "regression:validate-imports": "node scripts/validate-imports.js",
    "regression:nld-success": "node scripts/nld-log-success.js",
    "regression:all": "npm run test:build-validation && npm run test:cors-validation && npm run test:terminal-integration"
  },
  "dependencies": {
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "eventsource": "^4.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.5",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.0.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "redis": "^4.6.10",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@playwright/test": "^1.54.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitest/ui": "^3.2.4",
    "axios": "^1.11.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.54.2",
    "puppeteer": "^24.17.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "agent",
    "feed",
    "claude-flow",
    "automation",
    "neural"
  ],
  "author": "Agent Feed Team",
  "license": "MIT"
}
