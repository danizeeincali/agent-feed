#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit hooks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# ============================================================================
# 1. Lint Staged Files
# ============================================================================
echo "${YELLOW}📝 Linting staged files...${NC}"
if npm run lint 2>/dev/null; then
  echo "${GREEN}✓ Linting passed${NC}"
else
  echo "${RED}✗ Linting failed${NC}"
  FAILED=1
fi

# ============================================================================
# 2. TypeScript Type Checking
# ============================================================================
echo "${YELLOW}🔧 Running TypeScript type checking...${NC}"
if npm run typecheck 2>/dev/null; then
  echo "${GREEN}✓ Type checking passed${NC}"
else
  echo "${RED}✗ Type checking failed${NC}"
  FAILED=1
fi

# ============================================================================
# 3. Run Fast Unit Tests
# ============================================================================
echo "${YELLOW}🧪 Running fast unit tests...${NC}"
if npm run test -- --bail --maxWorkers=2 --passWithNoTests 2>/dev/null; then
  echo "${GREEN}✓ Unit tests passed${NC}"
else
  echo "${RED}✗ Unit tests failed${NC}"
  FAILED=1
fi

# ============================================================================
# 4. Check for Sensitive Files
# ============================================================================
echo "${YELLOW}🔐 Checking for sensitive files...${NC}"
SENSITIVE_FILES=$(git diff --cached --name-only | grep -E '\.(env|key|pem|p12|pfx)$' || true)
if [ -n "$SENSITIVE_FILES" ]; then
  echo "${RED}✗ Sensitive files detected:${NC}"
  echo "$SENSITIVE_FILES"
  echo "${RED}Please remove these files from the commit${NC}"
  FAILED=1
else
  echo "${GREEN}✓ No sensitive files detected${NC}"
fi

# ============================================================================
# 5. Check for Secrets in Code
# ============================================================================
echo "${YELLOW}🕵️  Checking for hardcoded secrets...${NC}"
SECRETS=$(git diff --cached | grep -iE '(api[_-]?key|password|secret|token|auth[_-]?key).*=.*["\'][a-zA-Z0-9]{20,}["\']' || true)
if [ -n "$SECRETS" ]; then
  echo "${RED}✗ Potential secrets detected in code:${NC}"
  echo "$SECRETS"
  echo "${YELLOW}⚠️  Please review and remove hardcoded secrets${NC}"
  FAILED=1
else
  echo "${GREEN}✓ No hardcoded secrets detected${NC}"
fi

# ============================================================================
# Final Result
# ============================================================================
echo ""
if [ $FAILED -eq 1 ]; then
  echo "${RED}❌ Pre-commit checks failed. Please fix the errors above.${NC}"
  exit 1
else
  echo "${GREEN}✅ All pre-commit checks passed!${NC}"
  exit 0
fi
