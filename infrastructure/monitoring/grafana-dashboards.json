            "h": 8,
            "w": 6,
            "x": 18,
            "y": 0
          },
          "targets": [
            {
              "expr": "incidents_open_total",
              "legendFormat": "Open Incidents",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "none",
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 1
                  },
                  {
                    "color": "red",
                    "value": 3
                  }
                ]
              }
            }
          }
