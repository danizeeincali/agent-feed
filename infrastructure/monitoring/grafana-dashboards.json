{
  "dashboards": [
    {
      "id": "system-overview",
      "title": "System Overview Dashboard",
      "tags": ["system", "overview", "production"],
      "timezone": "UTC",
      "refresh": "30s",
      "time": {
        "from": "now-1h",
        "to": "now"
      },
      "panels": [
        {
          "id": 1,
          "title": "CPU Usage",
          "type": "stat",
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
              "legendFormat": "CPU Usage %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              }
            }
          }
        },
        {
          "id": 2,
          "title": "Memory Usage",
          "type": "stat",
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 6,
            "y": 0
          },
          "targets": [
            {
              "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
              "legendFormat": "Memory Usage %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 80
                  },
                  {
                    "color": "red",
                    "value": 95
                  }
                ]
              }
            }
          }
        },
        {
          "id": 3,
          "title": "Disk Usage",
          "type": "stat",
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 12,
            "y": 0
          },
          "targets": [
            {
              "expr": "(1 - (node_filesystem_avail_bytes{fstype!=\"tmpfs\"} / node_filesystem_size_bytes{fstype!=\"tmpfs\"})) * 100",
              "legendFormat": "Disk Usage %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 80
                  },
                  {
                    "color": "red",
                    "value": 95
                  }
                ]
              }
            }
          }
        },
        {
          "id": 4,
          "title": "Network I/O",
          "type": "stat",
          "gridPos": {
            "h": 8,
            "w": 6,
            "x": 18,
            "y": 0
          },
          "targets": [
            {
              "expr": "rate(node_network_receive_bytes_total[5m]) + rate(node_network_transmit_bytes_total[5m])",
              "legendFormat": "Network I/O",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 5,
          "title": "Application Response Time",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 0,
            "y": 8
          },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
              "legendFormat": "50th percentile",
              "refId": "A"
            },
            {
              "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
              "legendFormat": "95th percentile",
              "refId": "B"
            },
            {
              "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
              "legendFormat": "99th percentile",
              "refId": "C"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 6,
          "title": "Request Rate",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 12,
            "y": 8
          },
          "targets": [
            {
              "expr": "rate(application_metrics{metric=\"requests_per_second\"}[5m])",
              "legendFormat": "Requests/sec",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        }
      ]
    },
    {
      "id": "performance-monitoring",
      "title": "Performance Monitoring Dashboard",
      "tags": ["performance", "bottlenecks", "optimization"],
      "timezone": "UTC",
      "refresh": "10s",
      "time": {
        "from": "now-30m",
        "to": "now"
      },
      "panels": [
        {
          "id": 10,
          "title": "Performance Bottlenecks",
          "type": "table",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "increase(performance_bottlenecks_total[5m])",
              "legendFormat": "{{type}} - {{severity}}",
              "refId": "A",
              "format": "table"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "displayMode": "list",
                "filterable": true
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "severity"
                },
                "properties": [
                  {
                    "id": "custom.cellOptions",
                    "value": {
                      "type": "color-background"
                    }
                  },
                  {
                    "id": "color",
                    "value": {
                      "mode": "thresholds"
                    }
                  },
                  {
                    "id": "thresholds",
                    "value": {
                      "steps": [
                        {
                          "color": "green",
                          "value": null
                        },
                        {
                          "color": "yellow",
                          "value": 1
                        },
                        {
                          "color": "red",
                          "value": 3
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 11,
          "title": "CPU Trend Analysis",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 0,
            "y": 8
          },
          "targets": [
            {
              "expr": "system_cpu_usage_percent",
              "legendFormat": "Current CPU",
              "refId": "A"
            },
            {
              "expr": "predict_linear(system_cpu_usage_percent[30m], 3600)",
              "legendFormat": "Predicted (1h)",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 12,
          "title": "Memory Trend Analysis",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 12,
            "y": 8
          },
          "targets": [
            {
              "expr": "system_memory_bytes{type=\"used\"} / system_memory_bytes{type=\"total\"} * 100",
              "legendFormat": "Current Memory",
              "refId": "A"
            },
            {
              "expr": "predict_linear((system_memory_bytes{type=\"used\"} / system_memory_bytes{type=\"total\"} * 100)[30m:], 3600)",
              "legendFormat": "Predicted (1h)",
              "refId": "B"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 13,
          "title": "Auto-scaling Events",
          "type": "logs",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 17
          },
          "targets": [
            {
              "expr": "{job=\"health-monitor\"} |= \"scaling\"",
              "refId": "A"
            }
          ]
        }
      ]
    },
    {
      "id": "security-monitoring",
      "title": "Security Monitoring Dashboard",
      "tags": ["security", "threats", "compliance"],
      "timezone": "UTC",
      "refresh": "30s",
      "time": {
        "from": "now-1h",
        "to": "now"
      },
      "panels": [
        {
          "id": 20,
          "title": "Security Events by Type",
          "type": "piechart",
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "increase(security_events_total[1h])",
              "legendFormat": "{{type}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 21,
          "title": "Threat Detection Score",
          "type": "gauge",
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 8,
            "y": 0
          },
          "targets": [
            {
              "expr": "security_risk_score",
              "legendFormat": "Risk Score",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "none",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 40
                  },
                  {
                    "color": "orange",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              }
            }
          }
        },
        {
          "id": 22,
          "title": "Compliance Score",
          "type": "gauge",
          "gridPos": {
            "h": 8,
            "w": 8,
            "x": 16,
            "y": 0
          },
          "targets": [
            {
              "expr": "security_compliance_score",
              "legendFormat": "Compliance",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 80
                  },
                  {
                    "color": "green",
                    "value": 95
                  }
                ]
              }
            }
          }
        },
        {
          "id": 23,
          "title": "Security Events Timeline",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 24,
            "x": 0,
            "y": 8
          },
          "targets": [
            {
              "expr": "rate(security_events_total{severity=\"critical\"}[5m])",
              "legendFormat": "Critical",
              "refId": "A"
            },
            {
              "expr": "rate(security_events_total{severity=\"high\"}[5m])",
              "legendFormat": "High",
              "refId": "B"
            },
            {
              "expr": "rate(security_events_total{severity=\"medium\"}[5m])",
              "legendFormat": "Medium",
              "refId": "C"
            },
            {
              "expr": "rate(security_events_total{severity=\"low\"}[5m])",
              "legendFormat": "Low",
              "refId": "D"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "events/sec",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        }
      ]
    },
    {
      "id": "error-recovery",
      "title": "Error Recovery Dashboard",
      "tags": ["errors", "recovery", "incidents"],
      "timezone": "UTC",
      "refresh": "30s",
      "time": {
        "from": "now-2h",
        "to": "now"
      },
      "panels": [
        {
          "id": 30,
          "title": "Error Rate",
