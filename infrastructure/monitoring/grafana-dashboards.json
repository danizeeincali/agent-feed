    },
    {
      "id": "health-monitoring",
      "title": "Health Monitoring Dashboard",
      "tags": ["health", "services", "uptime"],
      "timezone": "UTC",
      "refresh": "15s",
      "time": {
        "from": "now-1h",
        "to": "now"
      },
      "panels": [
        {
          "id": 40,
          "title": "Service Health Status",
          "type": "stat",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "health_check_status",
              "legendFormat": "{{service}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 0.5
                  },
                  {
                    "color": "green",
                    "value": 1
                  }
                ]
              },
              "mappings": [
                {
                  "options": {
                    "0": {
                      "text": "DOWN"
                    },
                    "1": {
                      "text": "UP"
                    }
                  },
                  "type": "value"
                }
              ]
            }
          }
        },
        {
          "id": 41,
          "title": "Health Check Response Time",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 0,
            "y": 8
          },
          "targets": [
            {
              "expr": "health_check_response_time",
              "legendFormat": "{{service}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 42,
          "title": "Service Uptime",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 12,
            "y": 8
          },
          "targets": [
            {
              "expr": "increase(health_check_success_total[1h]) / increase(health_check_total[1h]) * 100",
              "legendFormat": "{{service}} Uptime %",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        }
      ]
    },
    {
      "id": "alerts-overview",
      "title": "Alerts Overview Dashboard",
      "tags": ["alerts", "notifications", "escalations"],
      "timezone": "UTC",
      "refresh": "30s",
      "time": {
        "from": "now-24h",
        "to": "now"
      },
      "panels": [
        {
          "id": 50,
          "title": "Alert Summary",
          "type": "table",
          "gridPos": {
            "h": 10,
            "w": 24,
            "x": 0,
            "y": 0
          },
          "targets": [
            {
              "expr": "ALERTS",
              "legendFormat": "",
              "refId": "A",
              "format": "table"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "displayMode": "list",
                "filterable": true
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "severity"
                },
                "properties": [
                  {
                    "id": "custom.cellOptions",
                    "value": {
                      "type": "color-background"
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "id": 51,
          "title": "Alert Rate by Severity",
          "type": "timeseries",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 0,
            "y": 10
          },
          "targets": [
            {
              "expr": "rate(alerts_total{severity=\"critical\"}[5m])",
              "legendFormat": "Critical",
              "refId": "A"
            },
            {
              "expr": "rate(alerts_total{severity=\"high\"}[5m])",
              "legendFormat": "High",
              "refId": "B"
            },
            {
              "expr": "rate(alerts_total{severity=\"medium\"}[5m])",
              "legendFormat": "Medium",
              "refId": "C"
            },
            {
              "expr": "rate(alerts_total{severity=\"low\"}[5m])",
              "legendFormat": "Low",
              "refId": "D"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "alerts/sec",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        },
        {
          "id": 52,
          "title": "Alert Resolution Time",
          "type": "histogram",
          "gridPos": {
            "h": 9,
            "w": 12,
            "x": 12,
            "y": 10
          },
          "targets": [
            {
              "expr": "histogram_quantile(0.50, alert_resolution_time_bucket)",
              "legendFormat": "50th percentile",
              "refId": "A"
            },
            {
              "expr": "histogram_quantile(0.95, alert_resolution_time_bucket)",
              "legendFormat": "95th percentile",
              "refId": "B"
            },
            {
              "expr": "histogram_quantile(0.99, alert_resolution_time_bucket)",
              "legendFormat": "99th percentile",
              "refId": "C"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "m",
              "color": {
                "mode": "palette-classic"
              }
            }
          }
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": "prometheus",
        "enable": true,
        "expr": "changes(deployment_version[1h])",
        "iconColor": "rgba(0, 211, 255, 1)",
        "titleFormat": "Deployment: {{version}}",
        "tagKeys": "version,environment"
      },
      {
        "name": "Incidents",
        "datasource": "prometheus",
        "enable": true,
        "expr": "increase(incidents_created_total[1h])",
        "iconColor": "rgba(255, 96, 96, 1)",
        "titleFormat": "Incident: {{severity}}",
        "tagKeys": "severity,component"
      },
      {
        "name": "Scaling Events",
        "datasource": "prometheus",
        "enable": true,
        "expr": "increase(scaling_events_total[1h])",
        "iconColor": "rgba(96, 255, 96, 1)",
