    "model_architectures": {
      "expansion_prediction_model": {
        "type": "gradient_boosting",
        "features": ["content_features", "user_features", "context_features"],
        "hyperparameters": {
          "n_estimators": 100,
          "learning_rate": 0.1,
          "max_depth": 6
        },
        "validation": "k-fold_cross_validation",
        "performance_metrics": ["accuracy", "precision", "recall", "f1_score"]
      },
      "truncation_optimization_model": {
        "type": "neural_network",
        "architecture": "transformer_based",
        "layers": [
          {"type": "embedding", "dimensions": 128},
          {"type": "transformer", "heads": 8, "layers": 6},
          {"type": "dense", "units": 64, "activation": "relu"},
          {"type": "output", "units": 1, "activation": "sigmoid"}
        ],
        "training": {
          "optimizer": "adam",
          "loss": "binary_crossentropy",
          "batch_size": 32,
          "epochs": 50
