# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# ⚠️  CRITICAL SECURITY INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Replace ALL "CHANGE_ME_IN_PRODUCTION" values with secure values
# 3. NEVER commit .env.production to version control
# 4. Use strong passwords (32+ characters, mixed case, numbers, symbols)
# 5. Consider using Docker secrets or a secrets manager (Vault, AWS Secrets)
# 6. Rotate secrets regularly (every 90 days minimum)
# 7. Limit access to .env.production file (chmod 600)
# =============================================================================

# =============================================================================
# Node Environment
# =============================================================================

# Environment type - MUST be "production" for production deployments
NODE_ENV=production

# Logging level - "info" for production (use "debug" only for troubleshooting)
# Options: error, warn, info, debug
LOG_LEVEL=info

# Enable structured logging for production (JSON format for log aggregation)
LOG_FORMAT=json

# =============================================================================
# API Server Configuration
# =============================================================================

# API server port (use reverse proxy like nginx in front)
API_PORT=3001

# API host - 0.0.0.0 to listen on all interfaces (required for Docker)
API_HOST=0.0.0.0

# Public API URL (used for CORS, redirects, and absolute URLs)
PUBLIC_API_URL=CHANGE_ME_IN_PRODUCTION

# API request timeout (milliseconds) - production optimized
API_REQUEST_TIMEOUT_MS=60000

# Maximum request body size (for file uploads, etc.)
MAX_REQUEST_BODY_SIZE=10mb

# =============================================================================
# Directory Structure Configuration
# =============================================================================
# Production paths - update these based on your deployment architecture

# Root workspace directory (absolute path on production server)
WORKSPACE_ROOT=/opt/agent-feed

# Project root directory
PROJECT_ROOT=/opt/agent-feed

# Claude production directory (for production agent data)
CLAUDE_PROD_DIR=/opt/agent-feed/.claude

# Claude configuration directory (for agent configs)
CLAUDE_CONFIG_DIR=/opt/agent-feed/.claude/config

# Claude memory directory (for agent memory/state)
CLAUDE_MEMORY_DIR=/opt/agent-feed/.claude/memory

# Claude logs directory (for agent execution logs)
CLAUDE_LOGS_DIR=/opt/agent-feed/.claude/logs

# Agents directory (for agent definitions and templates)
AGENTS_DIR=/opt/agent-feed/agents

# Agent workspace directory (for agent runtime workspaces)
AGENT_WORKSPACE_DIR=/opt/agent-feed/agents/workspace

# Agent templates directory (for agent templates)
AGENT_TEMPLATES_DIR=/opt/agent-feed/agents/templates

# Database directory (for SQLite databases if not using PostgreSQL)
DATABASE_DIR=/opt/agent-feed/data

# Token analytics database path (for token usage tracking)
TOKEN_ANALYTICS_DB_PATH=/opt/agent-feed/data/token-analytics.db

# Agents configuration file path (for agent system configuration)
AGENTS_CONFIG_PATH=/opt/agent-feed/config/agents.json

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
# ⚠️  SECURITY WARNING: Use strong passwords for production databases
# Password requirements:
# - Minimum 32 characters
# - Include uppercase, lowercase, numbers, and special characters
# - Avoid dictionary words and common patterns
# - Use a password manager to generate and store

# Database name (separate database for production)
POSTGRES_DB=avidm_production

# Database user (create dedicated application user, NOT postgres superuser)
POSTGRES_USER=avidm_app

# Database password - ⚠️  CHANGE THIS IMMEDIATELY
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Database host (use private network/VPC address, not public IP)
# Examples:
# - Docker: postgres-container-name
# - AWS RDS: mydb.abc123.us-east-1.rds.amazonaws.com
# - Private IP: 10.0.1.100
DB_HOST=CHANGE_ME_IN_PRODUCTION

# Database port (default PostgreSQL port)
DB_PORT=5432

# Full connection string (automatically constructed from above values)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# =============================================================================
# PgBouncer Configuration (Optional - Recommended for Production)
# =============================================================================
# PgBouncer provides connection pooling at the database layer
# Uncomment these if using PgBouncer in front of PostgreSQL

# PGBOUNCER_HOST=localhost
# PGBOUNCER_PORT=6432
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${PGBOUNCER_HOST}:${PGBOUNCER_PORT}/${POSTGRES_DB}

# =============================================================================
# Database Connection Pool Settings (Application-Level)
# =============================================================================
# Production-optimized connection pool settings
# Formula: min = CPU cores × 1, max = CPU cores × 4
# Example for 8-core server: min=8, max=32

# Minimum connections in pool (kept alive)
DB_POOL_MIN=8

# Maximum connections in pool (scaled for production load)
DB_POOL_MAX=32

# Idle connection timeout (60 seconds for production)
DB_IDLE_TIMEOUT_MS=60000

# Connection acquisition timeout (5 seconds)
DB_CONNECTION_TIMEOUT_MS=5000

# Statement timeout (60 seconds for production queries)
DB_STATEMENT_TIMEOUT_MS=60000

# =============================================================================
# Database Selection (Dual Mode Support)
# =============================================================================
# Set to 'true' to use PostgreSQL (REQUIRED for production)
# Set to 'false' to use SQLite (development/testing only)
USE_POSTGRES=true

# =============================================================================
# Application User Configuration
# =============================================================================
# Password for non-superuser database access

# Application user password - ⚠️  CHANGE THIS IMMEDIATELY
APP_USER_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Claude API Configuration
# =============================================================================
# ⚠️  SECURITY WARNING: Protect your API keys
# - Never commit API keys to version control
# - Use environment variables or secrets manager
# - Rotate keys regularly
# - Monitor usage for anomalies

# Anthropic API key - ⚠️  CHANGE THIS IMMEDIATELY
ANTHROPIC_API_KEY=CHANGE_ME_IN_PRODUCTION

# Claude Model Selection (use latest production-stable models)
AGENT_MODEL=claude-sonnet-4-5-20250929
AVI_MODEL=claude-sonnet-4-5-20250929

# API rate limiting (requests per minute)
CLAUDE_API_RATE_LIMIT=50

# API retry configuration
CLAUDE_API_MAX_RETRIES=3
CLAUDE_API_RETRY_DELAY_MS=1000

# =============================================================================
# Security Headers Configuration
# =============================================================================
# Production security headers to protect against common attacks

# Enable HTTPS-only mode (requires SSL/TLS)
FORCE_HTTPS=true

# HTTP Strict Transport Security (HSTS)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# Content Security Policy (CSP)
CSP_ENABLED=true
CSP_DIRECTIVES="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'"

# X-Frame-Options (prevent clickjacking)
X_FRAME_OPTIONS=DENY

# X-Content-Type-Options (prevent MIME sniffing)
X_CONTENT_TYPE_OPTIONS=nosniff

# X-XSS-Protection (legacy XSS protection)
X_XSS_PROTECTION=1; mode=block

# Referrer Policy
REFERRER_POLICY=strict-origin-when-cross-origin

# =============================================================================
# CORS Configuration
# =============================================================================
# Cross-Origin Resource Sharing settings for production

# Allowed origins (comma-separated list of domains)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGIN=CHANGE_ME_IN_PRODUCTION

# Allow credentials (cookies, authorization headers)
CORS_CREDENTIALS=true

# Allowed HTTP methods
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Exposed headers (visible to client)
CORS_EXPOSED_HEADERS=Content-Length,Content-Range

# Preflight cache duration (24 hours)
CORS_MAX_AGE=86400

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Protect API endpoints from abuse and DDoS attacks

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Global rate limit (requests per window)
RATE_LIMIT_MAX_REQUESTS=100

# Rate limit window (milliseconds) - 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Skip rate limiting for trusted IPs (comma-separated)
RATE_LIMIT_SKIP_IPS=127.0.0.1

# Rate limit strategy (memory, redis)
RATE_LIMIT_STORE=memory

# Redis configuration for distributed rate limiting (if using Redis)
# RATE_LIMIT_REDIS_HOST=localhost
# RATE_LIMIT_REDIS_PORT=6379
# RATE_LIMIT_REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Session Configuration
# =============================================================================
# Session management for authenticated users

# Session secret - ⚠️  CHANGE THIS IMMEDIATELY (64+ character random string)
SESSION_SECRET=CHANGE_ME_IN_PRODUCTION

# Session lifetime (24 hours)
SESSION_MAX_AGE_MS=86400000

# Session cookie name
SESSION_COOKIE_NAME=avidm_session

# Secure cookie settings (HTTPS only in production)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict

# Session store (memory, redis)
SESSION_STORE=memory

# Redis configuration for session storage (if using Redis)
# SESSION_REDIS_HOST=localhost
# SESSION_REDIS_PORT=6379
# SESSION_REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# SSL/TLS Configuration
# =============================================================================
# SSL certificate paths (if terminating SSL at application level)
# Note: Typically handled by reverse proxy (nginx, HAProxy) in production

# SSL certificate file path
# SSL_CERT_PATH=/etc/ssl/certs/server.crt

# SSL private key file path
# SSL_KEY_PATH=/etc/ssl/private/server.key

# SSL CA certificate (for client authentication)
# SSL_CA_PATH=/etc/ssl/certs/ca.crt

# TLS version (minimum)
TLS_MIN_VERSION=1.2

# =============================================================================
# Health Check Settings
# =============================================================================
# Health check configuration for load balancers and monitoring

# Health check interval (30 seconds)
HEALTH_CHECK_INTERVAL=30000

# Health check endpoint path
HEALTH_CHECK_PATH=/health

# Enable detailed health check response
HEALTH_CHECK_DETAILED=false

# AVI context limit for monitoring
AVI_CONTEXT_LIMIT=50000

# =============================================================================
# Agent Worker Settings
# =============================================================================
# Agent execution configuration

# Maximum concurrent agent workers
MAX_AGENT_WORKERS=10

# Maximum retry attempts for failed agent tasks
RETRY_MAX_ATTEMPTS=3

# Retry backoff multiplier
RETRY_BACKOFF_MULTIPLIER=2

# Agent execution timeout (milliseconds) - 10 minutes
AGENT_EXECUTION_TIMEOUT_MS=600000

# =============================================================================
# Platform API Configuration
# =============================================================================
# External platform API credentials (if applicable)

# Platform API key - ⚠️  CHANGE THIS IF USING EXTERNAL PLATFORM
PLATFORM_API_KEY=CHANGE_ME_IN_PRODUCTION

# Platform API URL
PLATFORM_API_URL=CHANGE_ME_IN_PRODUCTION

# Platform API timeout (milliseconds)
PLATFORM_API_TIMEOUT_MS=30000

# =============================================================================
# Backup Settings
# =============================================================================
# Automated backup configuration

# Backup retention period (days)
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format) - Daily at 2 AM
BACKUP_SCHEDULE="0 2 * * *"

# Backup destination path
BACKUP_PATH=/opt/agent-feed/backups

# S3 backup configuration (optional)
# BACKUP_S3_ENABLED=true
# BACKUP_S3_BUCKET=CHANGE_ME_IN_PRODUCTION
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY_ID=CHANGE_ME_IN_PRODUCTION
# BACKUP_S3_SECRET_ACCESS_KEY=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Monitoring and Observability
# =============================================================================
# Application monitoring and metrics

# Enable application metrics
METRICS_ENABLED=true

# Metrics endpoint path
METRICS_PATH=/metrics

# Metrics port (separate from API port)
METRICS_PORT=9090

# APM (Application Performance Monitoring) configuration
# APM_ENABLED=true
# APM_SERVICE_NAME=agent-feed-production
# APM_SERVER_URL=CHANGE_ME_IN_PRODUCTION
# APM_SECRET_TOKEN=CHANGE_ME_IN_PRODUCTION

# Error tracking (Sentry, Rollbar, etc.)
# ERROR_TRACKING_ENABLED=true
# ERROR_TRACKING_DSN=CHANGE_ME_IN_PRODUCTION
# ERROR_TRACKING_ENVIRONMENT=production

# =============================================================================
# Docker Secrets (Recommended for Production)
# =============================================================================
# Use Docker secrets instead of environment variables for sensitive data
# Uncomment and configure when using Docker Swarm or Kubernetes secrets

# Database password from file
# DB_PASSWORD_FILE=/run/secrets/db_password

# Anthropic API key from file
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# Session secret from file
# SESSION_SECRET_FILE=/run/secrets/session_secret

# Platform API key from file
# PLATFORM_API_KEY_FILE=/run/secrets/platform_api_key

# =============================================================================
# Container Configuration
# =============================================================================
# Docker container names and network settings

# Container name for production deployment
CONTAINER_NAME=agent-feed-production

# Docker network name
DOCKER_NETWORK=agent-feed-network

# =============================================================================
# Cache Configuration
# =============================================================================
# Caching configuration for performance optimization

# Enable caching
CACHE_ENABLED=true

# Cache TTL (seconds) - 1 hour
CACHE_TTL=3600

# Cache store (memory, redis)
CACHE_STORE=memory

# Redis cache configuration (if using Redis)
# CACHE_REDIS_HOST=localhost
# CACHE_REDIS_PORT=6379
# CACHE_REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
# CACHE_REDIS_DB=0

# =============================================================================
# Feature Flags
# =============================================================================
# Enable/disable features in production

# Enable API documentation (Swagger/OpenAPI)
API_DOCS_ENABLED=false

# Enable debug endpoints (should be false in production)
DEBUG_ENDPOINTS_ENABLED=false

# Enable experimental features
EXPERIMENTAL_FEATURES_ENABLED=false

# =============================================================================
# Maintenance Mode
# =============================================================================
# Maintenance mode configuration

# Enable maintenance mode
MAINTENANCE_MODE=false

# Maintenance mode message
MAINTENANCE_MESSAGE="System is currently undergoing maintenance. Please try again later."

# =============================================================================
# Production Checklist
# =============================================================================
# Before deploying to production, verify:
#
# ✓ All CHANGE_ME_IN_PRODUCTION values are replaced
# ✓ Strong passwords are used (32+ characters)
# ✓ API keys are valid and from production accounts
# ✓ CORS origins are properly configured
# ✓ SSL/TLS is properly configured (or handled by reverse proxy)
# ✓ Database backups are configured and tested
# ✓ Monitoring and error tracking are enabled
# ✓ Log aggregation is configured
# ✓ Security headers are enabled
# ✓ Rate limiting is properly configured
# ✓ File permissions are restrictive (chmod 600 .env.production)
# ✓ Secrets are rotated from development values
# ✓ Health checks are working
# ✓ Load testing has been performed
# ✓ Disaster recovery plan is documented
#
# =============================================================================
