{
  "name": "agent-feed-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:with-typecheck": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run src/tests/unit/",
    "test:integration": "vitest run src/tests/integration/",
    "test:performance": "vitest run src/tests/performance/",
    "test:regression": "npx tsx src/tests/e2e/regression/test-runner.ts",
    "test:e2e": "playwright test src/tests/e2e/",
    "test:e2e:ui": "playwright test --ui",
    "test:regression:script": "./src/tests/e2e/regression/run-regression-tests.sh",
    "test:regression:report": "npx tsx src/tests/e2e/regression/test-runner.ts && open src/tests/reports/regression-test-report-*.html",
    "test:pipeline": "tsx src/tests/utils/test-runner.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:terminal": "jest --config src/tests/config/jest.terminal.config.js",
    "test:terminal:watch": "jest --config src/tests/config/jest.terminal.config.js --watch",
    "test:terminal:coverage": "jest --config src/tests/config/jest.terminal.config.js --coverage",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:docker": "playwright test --config=playwright.config.ts",
    "test:docker": "docker-compose -f tests/docker-compose.test.yml up --build --abort-on-container-exit",
    "test:docker:down": "docker-compose -f tests/docker-compose.test.yml down -v",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:sse": "tsx scripts/run-sse-comprehensive-tests.ts",
    "e2e:install": "playwright install",
    "playwright:install": "playwright install --with-deps",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.0.4",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@types/uuid": "^9.0.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^6.20.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "uuid": "^9.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.3",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporters": "^3.1.5",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "jsdom": "^26.1.0",
    "msw": "^2.10.5",
    "node-fetch": "^2.7.0",
    "playwright": "^1.55.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "tsx": "^4.20.5",
    "typescript": "^5.2.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "vitest-dom": "^0.1.1",
    "ws": "^8.14.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup/testSetup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy",
      "\\.(gif|ttf|eot|svg|png)$": "test-file-stub"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.stories.{ts,tsx}",
      "!src/tests/**/*",
      "!src/main.tsx",
      "!src/vite-env.d.ts"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "json"
    ],
    "coverageDirectory": "coverage",
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.(ts|tsx)",
      "<rootDir>/src/**/?(*.)(spec|test).(ts|tsx)"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-error-boundary|@tanstack)/)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
