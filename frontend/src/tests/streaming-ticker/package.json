{
  "name": "streaming-ticker-tests",
  "version": "1.0.0",
  "description": "Comprehensive test suite for streaming ticker functionality",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run unit/",
    "test:integration": "vitest run integration/",
    "test:component": "vitest run component/",
    "test:e2e": "playwright test",
    "test:performance": "vitest run performance/",
    "test:errors": "vitest run errors/",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:component && npm run test:performance && npm run test:errors",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit",
    "benchmark": "vitest bench",
    "test:debug": "vitest --inspect-brk --no-coverage --reporter=verbose",
    "test:leak": "vitest run --reporter=verbose --coverage=false performance/memory-usage.test.ts",
    "test:stress": "vitest run --reporter=verbose performance/stress-test.test.ts",
    "clean": "rm -rf coverage test-results.xml benchmark-results.json",
    "playwright:install": "playwright install",
    "playwright:update": "playwright install --with-deps"
  },
  "dependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.4.3",
    "@testing-library/jest-dom": "^6.1.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.1.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "testing",
    "streaming",
    "sse",
    "performance",
    "react",
    "typescript"
  ],
  "author": "Development Team",
  "license": "MIT"
}