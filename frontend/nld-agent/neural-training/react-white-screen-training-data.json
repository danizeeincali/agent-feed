{
  "trainingDataId": "RWS-Neural-2025-001",
  "datasetType": "Claude-Flow Neural Training Export",
  "version": "2.0.0",
  "timestamp": "2025-01-15T20:35:00Z",
  "patternSource": "react-white-screen-pattern.json",
  
  "neuralNetworkTargets": {
    "primaryModel": "failure_prediction_engine",
    "secondaryModels": [
      "component_dependency_analyzer",
      "error_boundary_validator", 
      "import_cascade_detector"
    ]
  },

  "trainingVectors": {
    "input_features": {
      "build_status": {
        "type": "categorical",
        "values": ["SUCCESS", "FAILED", "WARNING"],
        "encoding": "one_hot",
        "weight": 0.85
      },
      "runtime_status": {
        "type": "categorical", 
        "values": ["SUCCESS", "FAILED", "PARTIAL"],
        "encoding": "one_hot",
        "weight": 0.95
      },
      "component_complexity": {
        "type": "numerical",
        "range": [0, 1],
        "normalization": "min_max",
        "weight": 0.78
      },
      "import_chain_depth": {
        "type": "numerical",
        "range": [1, 20],
        "normalization": "z_score",
        "weight": 0.82
      },
      "error_boundary_count": {
        "type": "numerical", 
        "range": [0, 10],
        "normalization": "min_max",
        "weight": 0.88
      },
      "missing_component_refs": {
        "type": "numerical",
        "range": [0, 50],
        "normalization": "log_scale",
        "weight": 0.92
      },
      "path_alias_usage": {
        "type": "boolean",
        "encoding": "binary",
        "weight": 0.73
      },
      "route_count": {
        "type": "numerical",
        "range": [1, 100],
        "normalization": "sqrt_scale", 
        "weight": 0.65
      }
    },
    
    "output_labels": {
      "failure_probability": {
        "type": "regression",
        "range": [0, 1],
        "target": "continuous"
      },
      "failure_type": {
        "type": "classification",
        "classes": [
          "import_cascade_failure",
          "error_boundary_failure", 
          "component_mount_failure",
          "routing_failure",
          "dependency_failure"
        ]
      },
      "recovery_strategy": {
        "type": "classification",
        "classes": [
          "component_simplification",
          "error_boundary_fix",
          "import_repair",
          "fallback_activation"
        ]
      }
    }
  },

