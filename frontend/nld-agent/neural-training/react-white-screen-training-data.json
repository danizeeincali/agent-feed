  "patternRecognitionRules": {
    "critical_indicators": [
      {
        "condition": "build_status == 'SUCCESS' AND runtime_status == 'FAILED'",
        "weight": 0.95,
        "pattern": "build_runtime_mismatch"
      },
      {
        "condition": "missing_component_refs > 0 AND error_boundary_count > 1", 
        "weight": 0.90,
        "pattern": "component_reference_failure"
      },
      {
        "condition": "component_complexity > 0.8 AND import_chain_depth > 10",
        "weight": 0.85,
        "pattern": "complexity_cascade_risk"
      }
    ],
    
    "recovery_patterns": [
      {
        "trigger": "failure_type == 'import_cascade_failure'",
        "action": "component_simplification",
        "confidence": 0.88
      },
      {
        "trigger": "missing_component_refs > 2",
        "action": "import_repair", 
        "confidence": 0.92
      },
      {
        "trigger": "error_boundary_count > 5",
        "action": "error_boundary_fix",
        "confidence": 0.78
      }
    ]
  },

  "validationDataset": {
