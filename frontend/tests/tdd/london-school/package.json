{
  "name": "london-school-tdd-tests",
  "version": "1.0.0",
  "description": "London School TDD test suite for ClaudeServiceManager architecture",
  "private": true,
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:jest": "jest --config jest.config.js",
    "test:jest:watch": "jest --config jest.config.js --watch",
    "test:jest:coverage": "jest --config jest.config.js --coverage",
    "test:all": "npm run test && npm run test:jest",
    "test:coordination": "vitest run coordination --config vitest.config.ts",
    "test:contracts": "vitest run contracts --config vitest.config.ts",
    "test:unit": "vitest run unit --config vitest.config.ts",
    "test:integration": "vitest run integration --config vitest.config.ts",
    "test:e2e": "vitest run e2e --config vitest.config.ts",
    "test:regression": "vitest run regression --config vitest.config.ts",
    "coverage:report": "vitest run --coverage && open coverage/london-school/index.html",
    "coverage:analyze": "node scripts/analyze-coverage.js",
    "benchmark": "node scripts/benchmark-tests.js"
  },
  "keywords": [
    "tdd",
    "london-school",
    "mock-driven",
    "behavior-verification",
    "claude-instances",
    "testing"
  ],
  "dependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vitest": "^3.2.4",
    "vitest-dom": "^0.1.1"
  },
  "jest": {
    "preset": "../jest.config.js"
  }
}