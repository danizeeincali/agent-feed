FROM node:18-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    bash \
    netcat-openbsd \
    procps

# Copy terminal server file
COPY backend-terminal-server-emergency-fix.js ./

# Create minimal package.json for dependencies
RUN echo '{"dependencies":{"ws":"^8.13.0","child_process":"builtin"}}' > package.json

# Install dependencies
RUN npm install --production --silent

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S terminal -u 1001

# Set ownership
RUN chown -R terminal:nodejs /app

USER terminal

# Expose port
EXPOSE 3002

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD nc -z localhost 3002 || exit 1

# Start terminal server
CMD ["node", "backend-terminal-server-emergency-fix.js"]