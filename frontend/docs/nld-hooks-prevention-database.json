  },

  "violation_patterns": {
    "post_conditional_hooks": {
      "pattern": "if.*return.*useState|useEffect",
      "description": "Hooks declared after conditional returns",
      "examples": [
        {
          "file": "/workspaces/agent-feed/frontend/src/components/RealSocialMediaFeed.tsx",
          "lines": "549-566",
          "code": "if (loading) { return <Loading />; } const [claudeMessage] = useState();",
          "fix": "Move useState to line 53 area"
        }
      ],
      "risk_level": "critical",
      "auto_fixable": true
    },

    "loop_based_hooks": {
      "pattern": "map.*useState|forEach.*useEffect",
      "description": "Hooks called within loops causing variable hook counts",
      "examples": [],
      "risk_level": "critical",
      "auto_fixable": false
    },

    "nested_function_hooks": {
      "pattern": "function.*useState|const.*=>.*useEffect",
      "description": "Hooks called in nested functions instead of component body",
      "examples": [],
      "risk_level": "high",
      "auto_fixable": false
    },

    "conditional_hook_calls": {
      "pattern": "if.*{.*useState|condition.*useEffect",
      "description": "Hooks called conditionally based on props or state",
      "examples": [],
      "risk_level": "high",
      "auto_fixable": true
    }
  },

  "prevention_rules": {
    "hook_placement_rule": {
      "rule": "All hooks must be declared at the top of functional components",
      "enforcement": "eslint_custom_rule",
      "auto_fix": true,
      "examples": {
        "correct": "const Component = () => { const [state] = useState(); if (cond) return <Early />; return <Normal />; }",
        "incorrect": "const Component = () => { if (cond) return <Early />; const [state] = useState(); return <Normal />; }"
      }
    },

    "consistent_hook_count_rule": {
      "rule": "Hook count must remain consistent across all render paths",
      "enforcement": "runtime_validation_dev",
      "auto_fix": false,
      "validation_method": "useHookCountValidator"
    },

    "no_hooks_in_loops_rule": {
      "rule": "Never call hooks inside loops, conditions, or nested functions",
      "enforcement": "eslint_react_hooks_rules",
      "auto_fix": false,
      "alternative_pattern": "useMemo for conditional content"
    }
  },

  "detection_methods": {
    "static_analysis": {
      "tools": ["eslint", "typescript_compiler", "custom_ast_parser"],
      "patterns": [
        "post_return_hook_pattern",
