        "pattern": "conditional_content_pattern",
        "description": "Use useMemo for conditional rendering instead of early returns",
        "template": "const content = useMemo(() => condition ? <A /> : <B />, [condition]);",
        "benefits": ["consistent_hook_count", "better_performance", "clearer_logic"]
