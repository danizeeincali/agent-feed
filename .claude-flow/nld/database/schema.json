{
  "nlt_schema_version": "1.0.0",
  "record_structure": {
    "record_id": "string - unique identifier (timestamp-hash)",
    "timestamp": "ISO8601 datetime",
    "session_id": "string - claude session identifier",
    "task_context": {
      "original_task": "string - user's original request",
      "task_domain": "string - code/debug/feature/refactor/test",
      "task_complexity": "number - 1-10 complexity scale",
      "claude_solution": "string - Claude's proposed solution",
      "claude_confidence": "number - 0-1 confidence score"
    },
    "user_feedback": {
      "feedback_text": "string - user's actual response",
      "outcome": "success|failure|partial",
      "corrected_solution": "string - working solution if provided",
      "time_to_feedback": "number - minutes between solution and feedback"
    },
    "failure_analysis": {
      "failure_type": "logic|environment|dependency|integration|syntax|design",
      "root_cause": "string - detailed cause analysis",
      "tdd_used": "boolean - whether TDD was employed",
      "test_coverage": "number - 0-100 percentage if measurable"
    },
    "effectiveness_metrics": {
      "effectiveness_score": "number - calculated effectiveness rating",
      "user_success_rate": "number - 0-1 historical user success",
      "tdd_factor": "number - TDD impact multiplier",
      "pattern_frequency": "number - how common this failure pattern is"
    },
    "neural_integration": {
      "training_data_exported": "boolean",
      "pattern_classification": "string - ML classification label",
      "prediction_confidence": "number - 0-1 model confidence",
      "similar_patterns": "array - related pattern IDs"
    }
  },
  "indexes": {
    "by_timestamp": "timestamp",
    "by_domain": "task_context.task_domain", 
    "by_failure_type": "failure_analysis.failure_type",
    "by_effectiveness": "effectiveness_metrics.effectiveness_score",
    "by_tdd_usage": "failure_analysis.tdd_used"
  }
}