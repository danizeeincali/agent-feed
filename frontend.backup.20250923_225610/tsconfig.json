{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,
    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "src",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "src/agents/**/*",
    "src/services/neural-patterns.ts",
    "src/services/queen-chief-of-staff.ts",
    "src/utils/neural-utils.ts",
    "src/hooks/useBackgroundOrchestration.ts",
    "src/tests/**/*",
    "src/nld/**/*",
    "src/testing/**/*",
    "src/patterns/**/*",
    "src/services/connection/**/*",
    "src/hooks/useRobustWebSocket.ts",
    "src/hooks/useConnectionManager.ts",
    "src/debug/**/*",
    "src/utils/apiSafety.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
