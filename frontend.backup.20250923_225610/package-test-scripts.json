{
  "scripts": {
    "test": "jest",
    "test:unit": "node src/tests/test-runner.js unit",
    "test:integration": "node src/tests/test-runner.js integration",
    "test:e2e": "node src/tests/test-runner.js e2e",
    "test:performance": "node src/tests/test-runner.js performance",
    "test:regression": "node src/tests/test-runner.js regression",
    "test:all": "node src/tests/test-runner.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "npm run test:coverage && npm run test:e2e",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "playwright:install": "npx playwright install",
    "playwright:test": "npx playwright test",
    "playwright:report": "npx playwright show-report",
    "playwright:ui": "npx playwright test --ui"
  },
  "testCommands": {
    "Quick validation": "npm run test:unit",
    "Full regression": "npm run test:all",
    "Performance check": "npm run test:performance",
    "White screen prevention": "npm run test:regression",
    "User workflows": "npm run test:e2e",
    "Development workflow": "npm run test:watch",
    "CI/CD pipeline": "npm run test:ci"
  },
  "coverageThresholds": {
    "global": {
      "statements": 80,
      "branches": 75,
      "functions": 80,
      "lines": 80
    }
  },
  "performanceBudgets": {
    "renderTime": "1000ms",
    "bundleSize": "10MB",
    "memoryUsage": "50MB",
    "loadTime": {
      "3G": "10s",
      "4G": "5s",
      "WiFi": "2s"
    }
  }
}