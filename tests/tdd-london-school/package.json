{
  "name": "tdd-london-school-websocket-tests",
  "version": "1.0.0",
  "description": "TDD London School WebSocket command execution tests with comprehensive mock coverage",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:contracts": "jest contracts/",
    "test:mocks": "jest mocks/",
    "test:websocket": "jest websocket/",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint . --ext .ts,.js",
    "clean": "rm -rf coverage test-results node_modules"
  },
  "keywords": [
    "tdd",
    "london-school",
    "websocket",
    "mock-driven-development",
    "behavior-verification",
    "claude-cli",
    "testing"
  ],
  "author": "TDD London School Testing Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-feed/tdd-london-school.git"
