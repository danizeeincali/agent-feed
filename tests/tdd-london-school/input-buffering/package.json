{
  "name": "tdd-london-school-input-buffering",
  "version": "1.0.0",
  "description": "TDD London School Input Buffering Test Suite - Mock-driven behavior verification",
  "main": "jest.config.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest unit/",
    "test:integration": "jest integration/",
    "test:mocks": "jest mocks/",
    "test:contracts": "jest --testNamePattern=\"Contract\"",
    "test:verbose": "jest --verbose",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf coverage reports .jest-cache",
    "validate": "npm run lint && npm run test:ci"
  },
  "keywords": [
    "tdd",
    "london-school",
    "mockist",
    "input-buffering",
    "websocket",
    "behavior-verification",
    "contract-testing",
    "swarm-coordination"
  ],
  "author": "TDD London School Agent",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "babel-jest": "^29.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-html-reporters": "^3.1.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/utils/test-setup.js"],
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html", "json-summary"],
    "testMatch": [
      "<rootDir>/unit/**/*.test.js",
      "<rootDir>/integration/**/*.test.js"
    ]
  },
  "babel": {
    "presets": [
      ["@babel/preset-env", {
        "targets": {
          "node": "18"
        }
      }]
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "jest": true,
      "node": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-console": "warn",
      "prefer-const": "error",
      "no-var": "error"
    },
    "globals": {
      "global": "readonly",
      "expect": "readonly",
      "jest": "readonly",
      "describe": "readonly",
      "it": "readonly",
      "beforeEach": "readonly",
      "afterEach": "readonly",
      "beforeAll": "readonly",
      "afterAll": "readonly"
    }
  }
}