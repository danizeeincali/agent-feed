    "feature_engineering": {
      "input_features": [
        {
          "name": "component_type",
          "type": "categorical",
          "values": ["websocket_manager", "state_coordinator", "memory_manager", "error_handler"],
          "encoding": "one_hot"
        },
        {
          "name": "error_codes",
          "type": "categorical_array",
          "values": ["ECONNREFUSED", "CORS_ERROR", "TIMEOUT", "RACE_CONDITION", "STATE_CORRUPTION", "MEMORY_LEAK", "BLOB_URL_RETENTION", "UNHANDLED_REJECTION", "COMPONENT_ERROR"],
          "encoding": "multi_hot"
        },
        {
          "name": "environment",
          "type": "categorical",
          "values": ["browser", "react_component", "long_running_session", "user_interaction"],
          "encoding": "one_hot"
        },
        {
          "name": "timing",
          "type": "categorical",
          "values": ["connection_handshake", "concurrent_updates", "extended_usage", "error_occurrence"],
          "encoding": "one_hot"
        },
        {
          "name": "context_features",
          "type": "boolean_vector",
          "features": [
            "concurrent_connections", "fallback_available", "cors_configured", "health_monitoring",
            "async_operations", "state_serialization", "cleanup_handlers", "atomic_updates",
            "blob_cleanup", "event_cleanup", "memory_monitoring", "garbage_collection",
            "error_boundaries", "fallback_ui", "user_feedback", "recovery_options"
          ]
        }
      ],
      "output_features": [
        {
          "name": "classification",
          "type": "categorical",
          "values": ["websocket_connection_reliability", "state_management_race_conditions", "memory_leaks_chat_interface", "error_handling_gaps"],
          "encoding": "one_hot"
        },
        {
          "name": "severity_score",
          "type": "continuous",
          "range": [0.0, 1.0],
          "normalization": "min_max"
        },
        {
          "name": "prevention_priority",
          "type": "categorical_array",
          "values": ["fallback_implementation", "cors_configuration", "connection_monitoring", "message_queue", "atomic_operations", "cleanup_logic", "blob_url_management", "event_listener_cleanup", "memory_monitoring", "error_boundaries", "user_friendly_messages", "recovery_mechanisms"],
          "encoding": "priority_weighted"
        },
        {
          "name": "success_probability",
          "type": "continuous",
          "range": [0.0, 1.0],
          "normalization": "min_max"
        }
      ]
    },
    "model_configuration": {
      "architecture": "transformer_based",
      "layers": {
        "embedding_layer": {
          "input_dim": 64,
          "output_dim": 128,
          "dropout": 0.1
        },
        "transformer_blocks": {
          "num_blocks": 4,
          "attention_heads": 8,
          "hidden_dim": 512,
          "dropout": 0.1
        },
        "classification_head": {
          "hidden_layers": [256, 128],
          "output_dim": 4,
          "activation": "softmax"
        },
        "regression_heads": {
          "severity_head": {
            "hidden_layers": [128, 64],
            "output_dim": 1,
            "activation": "sigmoid"
          },
          "probability_head": {
            "hidden_layers": [128, 64],
            "output_dim": 1,
            "activation": "sigmoid"
          }
        }
      },
      "training_parameters": {
        "learning_rate": 0.001,
        "batch_size": 32,
        "epochs": 75,
        "optimizer": "adam",
        "loss_functions": {
