{
  "name": "claude-ui-tdd-tests",
  "version": "1.0.0",
  "description": "TDD London School tests for Claude UI modernization",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:accessibility": "jest --testNamePattern=\"accessibility|a11y\"",
    "test:visual": "jest --testNamePattern=\"visual|regression\"",
    "test:integration": "jest --testNamePattern=\"integration\"",
    "test:components": "jest --testNamePattern=\"Component|Button|Input|Chat|Message\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8",
    "@tanstack/react-query": "^5.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "./jest.config.js"
  },
  "keywords": [
    "tdd",
    "london-school",
    "react",
    "testing",
    "accessibility",
    "ui-components",
    "claude",
    "jest",
    "testing-library"
  ],
  "author": "Claude Code TDD Team",
  "license": "MIT"
}