{
  "name": "agent-feed-integration-tests",
  "version": "1.0.0",
  "description": "Comprehensive integration test suite for SDK and API endpoints",
  "private": true,
  "scripts": {
    "test": "ts-node test-runner.ts",
    "test:watch": "nodemon --exec \"npm run test\" --watch \"./**/*.ts\"",
    "test:debug": "DEBUG=true npm run test",
    "test:parallel": "PARALLEL=true npm run test",
    "test:coverage": "COVERAGE=true npm run test",
    "test:fail-fast": "FAIL_FAST=true npm run test",
    "test:avi-api": "jest --testPathPattern=avi-streaming-chat.test.ts",
    "test:claude-api": "jest --testPathPattern=claude-code-streaming-chat.test.ts",
    "test:streaming": "jest --testPathPattern=streaming-ticker-sse.test.ts",
    "test:websocket": "jest --testPathPattern=websocket-connections.test.ts",
    "test:validation": "jest --testPathPattern=comprehensive-validation.test.ts",
    "test:sdk": "jest --testPathPattern=avi-sdk-integration.test.ts",
    "test:mock": "jest --testPathPattern=mock-api-server",
    "test:specific": "jest --testPathPattern",
    "clean": "rimraf test-results coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "validate": "npm run lint && npm run format"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "ajv": "^8.12.0",
    "cors": "^2.8.5",
    "eventsource": "^2.0.2",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "node-fetch": "^2.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/node-fetch": "^2.6.9",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-plugin-jest": "^27.6.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>"],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost"
    },
    "collectCoverageFrom": [
      "**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/test-results/**"
    ],
    "coverageDirectory": "test-results/coverage",
    "coverageReporters": [
      "html",
      "text",
      "lcov",
      "json"
    ],
    "testTimeout": 30000,
    "detectOpenHandles": true,
    "forceExit": true,
    "maxWorkers": 1,
    "verbose": true
  },
  "eslintConfig": {
    "extends": [
      "@typescript-eslint/recommended",
      "plugin:jest/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "jest"
    ],
    "rules": {
      "@typescript-eslint/no-explicit-any": "off",
      "@typescript-eslint/no-unused-vars": "warn",
      "jest/no-disabled-tests": "warn",
      "jest/no-focused-tests": "error",
      "jest/prefer-to-have-length": "warn"
    },
    "env": {
      "node": true,
      "jest": true
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "integration-tests",
    "api-testing",
    "sdk-testing",
    "websocket-testing",
    "sse-testing",
    "agent-feed"
  ],
  "author": "Agent Feed Team",
  "license": "MIT"
}