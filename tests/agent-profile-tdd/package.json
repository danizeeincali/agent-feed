{
  "name": "agent-profile-tdd-suite",
  "version": "1.0.0",
  "description": "London School TDD Test Suite for Agent Profile Features",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:contracts": "jest contracts/",
    "test:unit": "jest unit/",
    "test:integration": "jest integration/",
    "test:e2e": "playwright test e2e/",
    "test:london-school": "npm run test:contracts && npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:swarm": "jest --config jest.swarm.config.js",
    "test:behavior": "jest contracts/agent-behavior.test.ts",
    "test:mocks": "jest --testNamePattern='Mock'",
    "test:interactions": "jest --testNamePattern='interaction|contract|behavior'",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint **/*.{ts,tsx} --fix",
    "lint:check": "eslint **/*.{ts,tsx}"
  },
  "dependencies": {
    "@jest/globals": "^30.1.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@playwright/test": "^1.55.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "London School TDD",
        "testMatch": ["<rootDir>/**/*.test.{ts,tsx}"],
        "setupFilesAfterEnv": ["<rootDir>/helpers/test-setup.ts"]
      }
    ]
  },
  "keywords": [
    "tdd",
    "london-school",
    "mocking",
    "behavior-driven",
    "testing",
    "swarm-coordination"
  ],
  "author": "Agent Feed Development Team",
  "license": "MIT"
}