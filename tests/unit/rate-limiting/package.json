{
  "name": "rate-limiting-tests",
  "version": "1.0.0",
  "description": "Comprehensive TDD test suite for rate limiting functionality",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:render-behavior": "jest rate-limit-render-behavior.test.tsx",
    "test:state-management": "jest rate-limit-state-management.test.tsx",
    "test:integration": "jest rate-limit-integration.test.tsx",
    "test:performance": "jest rate-limit-performance.test.tsx",
    "test:all": "jest --passWithNoTests",
    "test:verbose": "jest --verbose",
    "test:debug": "jest --detectOpenHandles --forceExit"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/../../jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.(ts|tsx|js)",
      "**/*.(test|spec).(ts|tsx|js)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../../../frontend/src/$1"
    },
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx",
            "lib": [
              "dom",
              "es2020"
            ]
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "../../../frontend/src/components/claude-manager/**/*.(ts|tsx)",
      "../../../frontend/src/hooks/**/*.(ts|tsx)",
      "!**/*.d.ts"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ts-jest": "^29.0.0"
  }
}
