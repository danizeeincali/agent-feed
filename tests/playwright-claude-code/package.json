{
  "name": "playwright-claude-code-tests",
  "version": "1.0.0",
  "description": "Comprehensive Playwright test suite for Claude Code integration",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:safari": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:edge": "playwright test --project='Microsoft Edge'",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "test:workflow": "playwright test specs/01-complete-workflow.spec.ts",
    "test:messages": "playwright test specs/02-message-handling.spec.ts",
    "test:tools": "playwright test specs/03-tool-usage-display.spec.ts",
    "test:regression": "playwright test specs/04-regression-tests.spec.ts",
    "test:visual": "playwright test specs/05-visual-regression.spec.ts",
    "test:performance": "playwright test specs/06-performance-benchmarks.spec.ts",
    "test:ci": "playwright test specs/07-ci-integration.spec.ts",
    "test:smoke": "playwright test specs/01-complete-workflow.spec.ts specs/04-regression-tests.spec.ts",
    "test:full": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:production": "NODE_ENV=production playwright test",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "playwright",
    "e2e-testing",
    "claude-code",
    "integration-testing",
    "production-validation"
  ]
}