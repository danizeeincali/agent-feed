{
  "name": "api-connectivity-tests",
  "version": "1.0.0",
  "type": "module",
  "description": "API Connectivity Tests for agent-feed project",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:e2e": "playwright test --config playwright.config.js",
    "test:e2e:ui": "playwright test --config playwright.config.js --ui",
    "test:e2e:headed": "playwright test --config playwright.config.js --headed",
    "test:e2e:debug": "playwright test --config playwright.config.js --debug",
    "test:all": "./run-api-tests.sh",
    "test:quick": "jest --config jest.config.js tests/api-connectivity/jest-api-connectivity.test.js",
    "test:health": "curl -f http://localhost:3000/api/health && curl -f http://localhost:5173 || echo 'Servers not ready'",
    "report:open": "playwright show-report test-results/api-connectivity-report",
    "clean": "rm -rf test-results && rm -rf playwright-report"
  },
  "keywords": [
    "api",
    "testing",
    "connectivity",
    "jest",
    "playwright",
    "e2e",
    "integration"
  ],
  "author": "TDD Testing Agent",
  "license": "MIT"
}