    -- ============================================================
    -- pattern_relationships: Cross-pattern learning and dependencies
    -- ============================================================
    CREATE TABLE IF NOT EXISTS pattern_relationships (
      -- Identity
      id TEXT PRIMARY KEY NOT NULL,
      source_pattern_id TEXT NOT NULL,
      target_pattern_id TEXT NOT NULL,
    
