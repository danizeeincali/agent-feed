    -- ============================================================
    -- Auto-update updated_at timestamp on patterns
    -- ============================================================
    CREATE TRIGGER IF NOT EXISTS trg_patterns_update_timestamp
    AFTER UPDATE ON patterns
    FOR EACH ROW
