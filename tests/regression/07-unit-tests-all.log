                      CASE WHEN NEW.outcome = 'success' THEN 1 ELSE 0 END +
                      CASE WHEN NEW.outcome = 'failure' THEN 1 ELSE 0 END,
        last_used_at = NEW.recorded_at,
        updated_at = strftime('%s', 'now') * 1000
      WHERE id = NEW.pattern_id;
    END;

