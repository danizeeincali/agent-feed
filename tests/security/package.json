{
  "name": "agent-feed-security-tests",
  "version": "1.0.0",
  "description": "Comprehensive security testing suite for dynamic pages",
  "scripts": {
    "test": "npm run test:security",
    "test:security": "npm run test:xss && npm run test:csrf && npm run test:input && npm run test:auth && npm run test:api && npm run test:csp",
    "test:xss": "vitest run xss-protection.spec.ts",
    "test:csrf": "mocha csrf-validation.js --timeout 10000",
    "test:input": "vitest run input-sanitization.spec.ts",
    "test:auth": "vitest run auth-testing.spec.ts",
    "test:api": "mocha api-security-scan.js --timeout 30000",
    "test:csp": "mocha csp-validation.js --timeout 20000",
    "scan:owasp": "npm run scan:zap && npm run scan:audit",
    "scan:zap": "zap-baseline.py -t http://localhost:3000 -J zap-report.json",
    "scan:audit": "npm audit --json > audit-report.json",
    "scan:ssl": "node security-scanner.js ssl",
    "scan:full": "node security-scanner.js full",
    "report:generate": "node generate-security-report.js",
    "ci:security": "npm run test:security && npm run scan:full && npm run report:generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/bcrypt": "^5.0.2",
    "@types/chai": "^4.3.11",
    "@types/crypto": "^1.0.4",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "chai": "^4.3.10",
    "dompurify": "^3.0.7",
    "jsdom": "^23.0.1",
    "jsonwebtoken": "^9.0.2",
    "mocha": "^10.2.0",
    "playwright": "^1.40.0",
    "puppeteer": "^21.6.1",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "cors": "^2.8.5"
  },
  "keywords": [
    "security",
    "testing",
    "owasp",
    "xss",
    "csrf",
    "authentication",
    "authorization",
    "csp",
    "vulnerability",
    "penetration"
  ],
  "author": "Security Team",
  "license": "MIT"
}