{
  "name": "frontend-api-validation-tests",
  "version": "1.0.0",
  "description": "TDD validation tests for Option 1: Frontend API service fix",
  "scripts": {
    "test": "jest --verbose --no-cache",
    "test:watch": "jest --watch --verbose",
    "test:coverage": "jest --coverage --verbose"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "jsdom": "^22.1.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true,
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/coverage/**"
    ]
  }
}