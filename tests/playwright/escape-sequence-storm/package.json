{
  "name": "escape-sequence-storm-tests",
  "version": "1.0.0",
  "description": "Comprehensive Playwright E2E tests for escape sequence storm prevention",
  "scripts": {
    "test": "node run-all-tests.js",
    "test:ci": "node run-ci-tests.js",
    "test:main": "playwright test main-e2e-suite.spec.ts",
    "test:storm": "playwright test storm-simulation.spec.ts",
    "test:concurrent": "playwright test multi-instance-concurrent.spec.ts",
    "test:stress": "playwright test stress-testing.spec.ts",
    "test:cross-browser": "playwright test cross-browser-validation.spec.ts",
    "test:smoke": "SMOKE_TEST=true playwright test main-e2e-suite.spec.ts",
    "test:performance": "PERFORMANCE_TEST=true playwright test stress-testing.spec.ts",
    "test:debug": "DEBUG=true playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project chromium-desktop",
    "test:firefox": "playwright test --project firefox-desktop",
    "test:webkit": "playwright test --project webkit-desktop",
    "test:mobile": "playwright test --project mobile-chrome,mobile-safari",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace",
    "install": "playwright install",
    "install:deps": "playwright install-deps",
    "clean": "rm -rf test-results artifacts",
    "validate": "node -e \"console.log('✅ Test suite is properly configured')\"",
    "setup": "npm run install && npm run install:deps && npm run validate"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "escape-sequence",
    "terminal",
    "storm-prevention",
    "browser-testing",
    "cross-browser",
    "performance-testing"
  ],
  "author": "Claude Code Development Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/agent-feed.git",
    "directory": "tests/playwright/escape-sequence-storm"
  },
  "bugs": {
    "url": "https://github.com/your-org/agent-feed/issues"
  },
  "homepage": "https://github.com/your-org/agent-feed#readme",
  "files": [
    "*.spec.ts",
    "page-objects/**/*",
    "utils/**/*",
    "fixtures/**/*",
    "playwright.config.ts",
    "run-all-tests.js",
    "run-ci-tests.js"
  ],
  "config": {
    "testTimeout": 60000,
    "retries": 1,
    "workers": 6,
    "browsers": [
      "chromium",
      "firefox",
      "webkit"
    ]
  },
  "playwright": {
    "version": "1.40.0",
    "browsers": [
      "chromium",
      "firefox",
      "webkit"
    ]
  }
}