{
  "name": "claude-tripling-bug-reproduction",
  "version": "1.0.0",
  "description": "E2E tests to reproduce and document Claude response tripling bug",
  "scripts": {
    "test:tripling": "playwright test --config=playwright-tripling-config.ts",
    "test:tripling:headed": "playwright test --config=playwright-tripling-config.ts --headed",
    "test:tripling:debug": "playwright test --config=playwright-tripling-config.ts --debug",
    "show:report": "playwright show-report tripling-bug-reports",
    "install:browsers": "playwright install chromium firefox"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "claude",
    "bug-reproduction",
    "tripling"
  ],
  "author": "Claude Code Testing Suite",
  "license": "MIT"
}