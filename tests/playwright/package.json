{
  "name": "agent-feed-playwright-tests",
  "version": "1.0.0",
  "description": "Playwright integration tests for Agent Feed port separation validation",
  "scripts": {
    "test": "playwright test --config=config/playwright.config.js",
    "test:headed": "playwright test --config=config/playwright.config.js --headed",
    "test:debug": "playwright test --config=config/playwright.config.js --debug",
    "test:ui": "playwright test --config=config/playwright.config.js --ui",
    "test:port-separation": "playwright test port-separation --config=config/playwright.config.js",
    "test:workflow": "playwright test comprehensive-workflow --config=config/playwright.config.js",
    "test:communication": "playwright test service-communication --config=config/playwright.config.js",
    "test:report": "playwright show-report reports/playwright-report",
    "install": "playwright install",
    "install:deps": "playwright install-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/eventsource": "^3.0.0",
    "eventsource": "^4.0.0",
    "playwright": "^1.55.0"
  },
  "main": "claude-instance-sse.spec.js",
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
