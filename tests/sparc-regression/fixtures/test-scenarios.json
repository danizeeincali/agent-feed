  "regressionScenarios": [
    {
      "id": "regression-001",
      "name": "Mention dropdown z-index conflict",
      "description": "Dropdown appears behind modal or header",
      "steps": [
        "Open post creator",
        "Type @ to show dropdown",
        "Open template library modal",
        "Verify dropdown is still visible and clickable"
      ],
      "expectedBehavior": "Dropdown has highest z-index and remains interactive"
    },
    
    {
      "id": "regression-002",
      "name": "Comment thread infinite expansion",
      "description": "Clicking expand causes infinite loop",
      "steps": [
        "Navigate to post with nested comments",
        "Click expand on root comment",
        "Rapidly click expand/collapse multiple times"
      ],
      "expectedBehavior": "Thread expands/collapses correctly without infinite loops"
    },
    
    {
      "id": "regression-003",
      "name": "WebSocket connection leak",
      "description": "Multiple connections created without cleanup",
      "steps": [
        "Navigate between pages multiple times",
        "Monitor network connections",
        "Check WebSocket connection count"
      ],
      "expectedBehavior": "Only one WebSocket connection active at a time"
    },
    
    {
      "id": "regression-004",
      "name": "API race condition on rapid posting",
      "description": "Rapid form submission causes duplicate posts",
      "steps": [
        "Fill post creation form",
        "Click submit multiple times rapidly",
        "Check if multiple posts created"
      ],
      "expectedBehavior": "Only one post created regardless of rapid clicking"
    },
    
    {
      "id": "regression-005", 
      "name": "State sync bug between feed and creator",
      "description": "New posts don't appear in feed after creation",
      "steps": [
        "Create new post",
        "Verify post appears in creator success state", 
        "Check if post appears in main feed",
        "Refresh page and verify persistence"
      ],
      "expectedBehavior": "New posts immediately appear in feed and persist after refresh"
    }
  ],

