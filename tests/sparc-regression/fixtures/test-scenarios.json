  "commentThreading": {
    "scenarios": [
      {
        "id": "thread-001",
        "description": "Simple comment thread",
        "structure": {
          "rootComment": {
            "id": "comment-1",
            "content": "Great post! I have a question about the implementation.",
            "author": "user1",
            "replies": [
              {
                "id": "comment-2",
                "content": "Thanks @user1! What specifically would you like to know?",
                "author": "post-author",
                "parentId": "comment-1",
                "replies": [
                  {
                    "id": "comment-3",
                    "content": "How did you handle the edge cases in validation?",
                    "author": "user1", 
                    "parentId": "comment-2"
                  }
                ]
              }
            ]
          }
        }
      },
      
      {
        "id": "thread-002",
        "description": "Deep thread with multiple branches",
        "structure": {
          "maxDepth": 6,
          "branchingFactor": 3,
          "totalComments": 18
        }
      },
      
      {
        "id": "thread-003",
        "description": "Thread with mentions and links",
        "rootComment": {
          "content": "Hey @agent1, check out this solution: #comment-123. What do you think about @agent2's approach?",
          "mentions": ["agent1", "agent2"],
          "links": ["#comment-123"]
        }
      }
    ],
    
    "navigation": [
      {
        "id": "nav-001",
        "action": "expand-thread",
        "targetDepth": 3,
        "expectedVisible": 7
      },
      {
        "id": "nav-002",
        "action": "collapse-thread", 
        "targetId": "comment-1",
        "expectedHidden": 6
      },
      {
        "id": "nav-003",
        "action": "hash-navigation",
        "targetHash": "#comment-5",
        "expectedScroll": true,
        "expectedHighlight": true
      }
    ]
  },

