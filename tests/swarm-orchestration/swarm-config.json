{
  "swarmConfiguration": {
    "topology": "hierarchical",
    "maxAgents": 25,
    "executionStrategy": "concurrent",
    "communicationProtocol": "message-passing",
    "scalingPolicy": "adaptive"
  },
  "agents": {
    "testCoordinator": {
      "type": "hierarchical-coordinator",
      "role": "primary",
      "capabilities": ["orchestration", "delegation", "monitoring"],
      "maxConcurrentTasks": 10,
      "healthCheckInterval": 5000,
      "failureThreshold": 3
    },
    "tddExecutors": {
      "type": "tdd-london-swarm",
      "count": 5,
      "role": "worker",
      "capabilities": ["test-execution", "mocking", "isolation"],
      "specialization": "london-school-tdd",
      "maxConcurrentTests": 4,
      "testTimeout": 30000
    },
    "sparcValidators": {
      "type": "sparc-coord",
      "count": 4,
      "role": "validator",
      "capabilities": ["specification", "architecture", "validation"],
      "phases": ["spec", "pseudocode", "architecture", "refinement"],
      "validationTimeout": 15000
    },
    "nldMonitors": {
      "type": "smart-agent",
      "count": 3,
      "role": "monitor",
      "capabilities": ["pattern-detection", "anomaly-detection", "learning"],
      "patterns": ["regression", "performance", "failure"],
      "learningRate": 0.1
    },
    "playwrightAgents": {
      "type": "production-validator",
      "count": 6,
      "role": "e2e-tester",
      "capabilities": ["browser-automation", "visual-testing", "performance"],
      "browsers": ["chromium", "firefox", "webkit"],
      "parallelism": 3
    },
    "resultAggregators": {
      "type": "perf-analyzer",
      "count": 2,
      "role": "aggregator",
      "capabilities": ["data-collection", "analysis", "reporting"],
      "metrics": ["coverage", "performance", "reliability"],
      "reportFormats": ["json", "xml", "html"]
    }
  },
  "testSuites": {
    "regression": {
      "priority": "high",
      "timeout": 300000,
      "parallelism": 10,
      "agents": ["tddExecutors", "sparcValidators"],
      "testPatterns": [
        "/tests/regression/**/*.test.js",
        "/tests/tdd-london-school/**/*.test.js"
      ]
    },
    "integration": {
      "priority": "high",
      "timeout": 600000,
      "parallelism": 8,
      "agents": ["tddExecutors", "nldMonitors"],
      "testPatterns": [
        "/tests/integration/**/*.test.js",
        "/tests/e2e/**/*.test.js"
      ]
    },
    "e2e": {
      "priority": "medium",
      "timeout": 900000,
      "parallelism": 6,
      "agents": ["playwrightAgents", "nldMonitors"],
      "testPatterns": [
        "/tests/playwright/**/*.spec.ts",
        "/tests/e2e/**/*.spec.ts"
      ]
    },
    "performance": {
      "priority": "medium", 
      "timeout": 1200000,
      "parallelism": 4,
      "agents": ["resultAggregators", "nldMonitors"],
      "testPatterns": [
        "/tests/performance/**/*.test.js",
        "/tests/performance/**/*.test.ts"
      ]
    }
  },
  "communication": {
    "messageQueue": {
      "type": "in-memory",
      "maxSize": 10000,
      "retryAttempts": 3,
      "retryDelay": 1000
    },
    "statusBroadcast": {
      "interval": 2000,
      "channels": ["progress", "errors", "metrics"],
      "compression": true
    },
    "coordination": {
      "heartbeatInterval": 5000,
      "syncPoints": ["test-start", "test-complete", "error"],
      "barrierTimeout": 30000
    }
  },
  "failureHandling": {
    "isolation": {
      "enabled": true,
      "strategy": "circuit-breaker",
      "threshold": 5,
      "timeout": 60000,
      "fallback": "skip-and-continue"
    },
    "recovery": {
      "autoRestart": true,
      "maxRestarts": 3,
      "backoffStrategy": "exponential",
      "baseDelay": 2000
    },
    "cascadePrevention": {
      "enabled": true,
      "maxFailureRate": 0.2,
      "emergencyStop": true,
      "gracefulShutdown": 30000
    }
  },
  "monitoring": {
    "metrics": {
      "collection": ["memory", "cpu", "network", "test-results"],
      "interval": 1000,
      "retention": "1h",
      "aggregation": ["avg", "max", "p95", "p99"]
    },
    "alerts": {
      "thresholds": {
        "memoryUsage": 0.8,
        "cpuUsage": 0.9,
        "testFailureRate": 0.1,
        "responseTime": 10000
      },
      "channels": ["console", "file", "webhook"],
      "cooldown": 60000
    }
  },
  "performance": {
    "targets": {
      "totalExecutionTime": 300000,
      "speedupFactor": 10,
      "testFlakiness": 0.01,
      "concurrentAgents": 20
    },
    "optimization": {
      "testSharding": true,
      "loadBalancing": "capability-based",
      "resourcePooling": true,
      "caching": ["dependencies", "artifacts", "results"]
    }
  }
}