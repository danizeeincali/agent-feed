{
  "name": "@agent-feed/swarm-orchestration",
  "version": "1.0.0",
  "description": "Claude-Flow Swarm Concurrent Test Orchestration System",
  "main": "run-swarm-tests.js",
  "bin": {
    "swarm-test": "./run-swarm-tests.js"
  },
  "scripts": {
    "test": "node run-swarm-tests.js --suite=regression --parallelism=5",
    "test:all": "node run-swarm-tests.js --suite=regression,integration,e2e,performance --parallelism=10",
    "test:regression": "node run-swarm-tests.js --suite=regression --parallelism=8",
    "test:integration": "node run-swarm-tests.js --suite=integration --parallelism=6",
    "test:e2e": "node run-swarm-tests.js --suite=e2e --parallelism=4 --browser=chromium",
    "test:performance": "node run-swarm-tests.js --suite=performance --parallelism=3",
    "test:ci": "node run-swarm-tests.js --suite=regression,integration --parallelism=10 --ci-mode=true --timeout=15",
    "validate-config": "node -e \"const config = require('./swarm-config.json'); console.log('✅ Configuration valid')\"",
    "benchmark": "node benchmark/swarm-performance-test.js",
    "demo": "node demo/swarm-demo.js",
    "init": "npm install && npx playwright install --with-deps",
    "health-check": "node -e \"console.log('Swarm orchestration system: OK')\""
  },
  "keywords": [
    "swarm",
    "orchestration",
    "testing",
    "parallel",
    "claude-flow",
    "tdd",
    "sparc",
    "e2e",
    "performance",
    "ci-cd"
  ],
  "author": "Claude-Flow Swarm Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0"
  },
  "peerDependencies": {
    "claude-flow": "alpha"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-feed/swarm-orchestration.git"
  },
  "bugs": {
    "url": "https://github.com/agent-feed/swarm-orchestration/issues"
  },
  "homepage": "https://github.com/agent-feed/swarm-orchestration#readme",
  "directories": {
    "test": "tests"
  },
  "config": {
    "swarm": {
      "maxAgents": 25,
      "defaultTimeout": 300000,
      "defaultParallelism": 10
    }
  }
}