{
  "name": "agent-feed-tdd-tests",
  "version": "1.0.0",
  "description": "TDD London School test suite for Claude process launcher",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration",
    "test:unit": "jest tests/ --ignore-pattern tests/integration",
    "test:contracts": "jest tests/mock-contracts.test.js",
    "test:behavior": "jest --verbose --reporters=default --testResultsProcessor=./processors/behavior-verification-processor.js",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "lint:tests": "eslint tests/**/*.{js,jsx} --fix"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^30.0.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^30.0.5",
    "eslint": "^8.56.0",
    "eslint-plugin-jest": "^27.6.0",
    "jest": "^29.7.0",
    "jest-extended": "^6.0.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "supertest": "^7.1.4"
  }
}
